msgid ""
msgstr ""
"Project-Id-Version: Purchase Contract Withdrawal Button for WooCommerce 1.3.0\n"
"Report-Msgid-Bugs-To: \n"
"POT-Creation-Date: 2026-05-25 10:00+0000\n"
"PO-Revision-Date: 2026-05-29 12:00+0000\n"
"Last-Translator: Jakub Kašpárek\n"
"Language-Team: Croatian\n"
"Language: hr\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=3; plural=(n%10==1 && n%100!=11 ? 0 : n%10>=2 && n%10<=4 && (n%100<10 || n%100>=20) ? 1 : 2);\n"
"X-Domain: purchase-contract-withdrawal-button-for-woocommerce\n"

msgid "Purchase Contract Withdrawal Button for WooCommerce requires WooCommerce to be installed and active."
msgstr "Dodatak Purchase Contract Withdrawal Button for WooCommerce zahtijeva instaliran i aktivan WooCommerce."

msgid "Settings"
msgstr "Postavke"

msgid "Withdraw from purchase contract"
msgstr "Odustani od ugovora o kupnji"

msgid "This order is no longer eligible for withdrawal (the cooling-off period has expired, or a withdrawal has already been submitted)."
msgstr "Ova narudžba više nije prihvatljiva za odustajanje (razdoblje odustajanja je isteklo ili je odustajanje već podneseno)."

msgid "Back to order"
msgstr "Natrag na narudžbu"

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email. We will be in touch with return instructions."
msgstr "Vaše odustajanje je podneseno. Potvrda je poslana na vašu e-mail adresu. Javit ćemo vam se s uputama za povrat robe."

msgid "Withdrawal has been submitted"
msgstr "Odustajanje je podneseno"

#. translators: %s: submission date
msgid "on %s."
msgstr "dana %s."

#. translators: %s: admin email address
msgid "If you have any questions, contact us at %s."
msgstr "Ako imate pitanja, kontaktirajte nas na %s."

msgid "You must be logged in to submit a withdrawal."
msgstr "Morate biti prijavljeni za podnošenje odustajanja."

msgid "Invalid order."
msgstr "Nevažeća narudžba."

msgid "Security check failed. Please go back and try again."
msgstr "Sigurnosna provjera nije uspjela. Vratite se i pokušajte ponovno."

msgid "You are not authorized to access this order."
msgstr "Nemate ovlaštenje za pristup ovoj narudžbi."

msgid "You must check the confirmation box to submit a withdrawal."
msgstr "Morate označiti potvrdni okvir za podnošenje odustajanja."

msgid "This order is no longer eligible for withdrawal."
msgstr "Ova narudžba više nije prihvatljiva za odustajanje."

msgid "Customer submitted a withdrawal from the purchase contract."
msgstr "Kupac je podnio odustajanje od ugovora o kupnji."

#. translators: %s: customer-provided reason
msgid "Reason: %s"
msgstr "Razlog: %s"

#. translators: %s: bank account for refund
msgid "Refund account: %s"
msgstr "Račun za povrat: %s"

msgid "Customer submitted withdrawal from purchase contract."
msgstr "Kupac je podnio odustajanje od ugovora o kupnji."

msgid "Withdrawal confirmation (customer)"
msgstr "Potvrda odustajanja (kupac)"

msgid "Sent to the customer after they submit a withdrawal from a purchase contract."
msgstr "Šalje se kupcu nakon podnošenja odustajanja od ugovora o kupnji."

msgid "[{site_title}] Withdrawal confirmation — order #{order_number}"
msgstr "[{site_title}] Potvrda odustajanja — narudžba #{order_number}"

msgid "Withdrawal confirmation"
msgstr "Potvrda odustajanja"

msgid "If you have any questions about your withdrawal, please reply to this email."
msgstr "Ako imate pitanja o svom odustajanju, odgovorite na ovaj e-mail."

msgid "Withdrawal notification (admin)"
msgstr "Obavijest o odustajanju (administrator)"

msgid "Sent to the store administrator when a customer submits a withdrawal."
msgstr "Šalje se administratoru trgovine kada kupac podnese odustajanje."

msgid "[{site_title}] New withdrawal request — order #{order_number}"
msgstr "[{site_title}] Novi zahtjev za odustajanje — narudžba #{order_number}"

msgid "New withdrawal request"
msgstr "Novi zahtjev za odustajanje"

msgid "Enable/Disable"
msgstr "Omogući/Onemogući"

msgid "Enable this email notification"
msgstr "Omogući ovu e-mail obavijest"

msgid "Recipient(s)"
msgstr "Primatelji"

#. translators: %s: admin email
msgid "Enter recipients (comma separated). Defaults to %s."
msgstr "Unesite primatelje (odvojene zarezom). Zadano: %s."

msgid "Subject"
msgstr "Predmet"

msgid "Placeholders: %s"
msgstr "Rezervirana mjesta: %s"

msgid "Email heading"
msgstr "Naslov e-maila"

msgid "Email type"
msgstr "Vrsta e-maila"

msgid "Choose which format of email to send."
msgstr "Odaberite u kojem formatu poslati e-mail."

msgid "Purchase Contract Withdrawal Button for WooCommerce"
msgstr "Gumb za odustajanje od ugovora o kupnji"

msgid "Withdrawal Button"
msgstr "Gumb za odustajanje"

#. translators: %s: WooCommerce email settings URL
msgid "Customer and admin email templates can be customized in %s."
msgstr "Predlošci e-mailova za kupce i administratore mogu se prilagoditi u %s."

msgid "WooCommerce → Settings → Emails"
msgstr "WooCommerce → Postavke → E-mailovi"

msgid "Cooling-off period (days)"
msgstr "Razdoblje odustajanja (dani)"

msgid "How long after the reference date (order completion) the withdrawal button stays visible. EU standard is 14 days."
msgstr "Koliko dugo nakon referentnog datuma (dovršenja narudžbe) gumb za odustajanje ostaje vidljiv. EU standard je 14 dana."

msgid "Eligible order statuses"
msgstr "Prihvatljivi statusi narudžbe"

msgid "The button is shown only for orders in one of these statuses."
msgstr "Gumb se prikazuje samo za narudžbe u jednom od ovih statusa."

msgid "Admin email recipient"
msgstr "Primatelj administratorskog e-maila"

#. translators: %s: admin email
msgid "Leave empty to use the site admin email (%s)."
msgstr "Ostavite prazno za korištenje administratorskog e-maila stranice (%s)."

msgid "Status after submission"
msgstr "Status nakon podnošenja"

msgid "Order status applied automatically after the customer submits a withdrawal."
msgstr "Status narudžbe koji se automatski primjenjuje nakon što kupac podnese odustajanje."

msgid "Withdrawal from purchase contract"
msgstr "Odustajanje od ugovora o kupnji"

#. translators: 1: order number, 2: deadline date
msgid "Complete the form below to withdraw from purchase contract no. %1$s. The cooling-off period ends on %2$s."
msgstr "Ispunite donji obrazac za odustajanje od ugovora o kupnji br. %1$s. Razdoblje odustajanja završava %2$s."

msgid "Order number"
msgstr "Broj narudžbe"

msgid "Order date"
msgstr "Datum narudžbe"

msgid "Customer"
msgstr "Kupac"

msgid "Address"
msgstr "Adresa"

msgid "Email"
msgstr "E-mail"

msgid "Total"
msgstr "Ukupno"

msgid "Bank account for refund"
msgstr "Bankovni račun za povrat"

msgid "(optional — leave empty to refund to the original payment method)"
msgstr "(neobavezno — ostavite prazno za povrat na izvornu metodu plaćanja)"

msgid "Reason for withdrawal"
msgstr "Razlog odustajanja"

msgid "(optional)"
msgstr "(neobavezno)"

msgid "I confirm that I am withdrawing from the purchase contract"
msgstr "Potvrđujem da odustajem od ugovora o kupnji"

msgid "and I understand that I must return the purchased goods within 14 days of submitting this withdrawal. The refund will be issued after the returned goods are received."
msgstr "i razumijem da moram vratiti kupljenu robu u roku od 14 dana od podnošenja ovog odustajanja. Povrat sredstava bit će izvršen nakon primitka vraćene robe."

msgid "Confirm withdrawal"
msgstr "Potvrdi odustajanje"

msgid "Cancel"
msgstr "Odustani"

msgid "Hello,"
msgstr "Pozdrav,"

#. translators: 1: order number, 2: order date
msgid "We have received your withdrawal from the purchase contract for order no. %1$s placed on %2$s."
msgstr "Primili smo vaše odustajanje od ugovora o kupnji za narudžbu br. %1$s naručenu dana %2$s."

msgid "Next steps"
msgstr "Sljedeći koraci"

msgid "Next steps:"
msgstr "Sljedeći koraci:"

msgid "Please return the goods to our address within 14 days of submitting this withdrawal."
msgstr "Molimo vratite robu na našu adresu u roku od 14 dana od podnošenja ovog odustajanja."

msgid "We recommend shipping with tracking and insurance."
msgstr "Preporučujemo slanje s praćenjem i osiguranjem."

#. translators: %s: total amount
msgid "Once we receive the goods we will refund the paid amount (%s) within 14 days."
msgstr "Nakon primitka robe vratit ćemo plaćeni iznos (%s) u roku od 14 dana."

msgid "A customer has submitted a withdrawal from a purchase contract."
msgstr "Kupac je podnio odustajanje od ugovora o kupnji."

msgid "Order"
msgstr "Narudžba"

msgid "Phone"
msgstr "Telefon"

msgid "Completion date"
msgstr "Datum dovršetka"

msgid "Refund account"
msgstr "Račun za povrat"

msgid "Original payment method"
msgstr "Izvorna metoda plaćanja"

msgid "Reason"
msgstr "Razlog"

msgid "(not provided)"
msgstr "(nije navedeno)"

msgid "View order:"
msgstr "Pogledaj narudžbu:"

# === 1.2.0 strings ===

msgid "A withdrawal has already been submitted for this order."
msgstr "Za ovu narudžbu već je podneseno odustajanje."

msgid "an administrator"
msgstr "administrator"

msgid "Customer (guest) submitted a withdrawal from the purchase contract."
msgstr "Kupac (gost) je podnio odustajanje od ugovora o kupnji."

#. translators: %s: admin display name
msgid "Withdrawal marked as resolved by %s."
msgstr "Korisnik %s je označio odustajanje kao riješeno."

#. translators: %s: admin display name
msgid "Withdrawal submitted on behalf of the customer by %s."
msgstr "Korisnik %s je podnio odustajanje u ime kupca."

msgid "The withdrawal form is not currently available. Please contact the store."
msgstr "Obrazac za odustajanje trenutno nije dostupan. Molimo kontaktirajte trgovinu."

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email."
msgstr "Vaše odustajanje je podneseno. Potvrda je poslana na vašu e-mail adresu."

msgid "Your session has expired. Please start the lookup again."
msgstr "Vaša sesija je istekla. Molimo započnite pretragu ponovno."

msgid "Order not found."
msgstr "Narudžba nije pronađena."

msgid "Order number or email is missing or invalid."
msgstr "Broj narudžbe ili e-mail nedostaje ili je nevažeći."

msgid "We could not find an order with the provided details."
msgstr "Nismo mogli pronaći narudžbu s navedenim podacima."

msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "Previše pokušaja. Pričekajte nekoliko minuta i pokušajte ponovno."

msgid "Security check failed. Please try again."
msgstr "Sigurnosna provjera nije uspjela. Pokušajte ponovno."

msgid "Enter your order number and the email address used when placing the order to continue."
msgstr "Za nastavak unesite broj narudžbe i e-mail adresu korištenu prilikom narudžbe."

msgid "Billing email"
msgstr "E-mail za naplatu"

msgid "Continue"
msgstr "Nastavi"

msgid "Withdrawal cooling-off"
msgstr "Razdoblje odustajanja"

msgid "Date of delivery"
msgstr "Datum isporuke"

msgid "Date the customer received the goods. Used as the reference date for the cooling-off period (leave empty to use the order completion date)."
msgstr "Datum kada je kupac primio robu. Koristi se kao referentni datum za razdoblje odustajanja (ostavite prazno za korištenje datuma dovršetka narudžbe)."

msgid "Cooling-off ends:"
msgstr "Razdoblje odustajanja završava:"

#. translators: %d: number of days remaining
msgid "%d day remaining"
msgid_plural "%d days remaining"
msgstr[0] "preostao %d dan"
msgstr[1] "preostala %d dana"
msgstr[2] "preostalo %d dana"

msgid "expired"
msgstr "isteklo"

msgid "Withdrawal submitted:"
msgstr "Odustajanje podneseno:"

msgid "Resolved:"
msgstr "Riješeno:"

msgid "Use the Order actions box to mark this withdrawal as resolved."
msgstr "Koristite okvir Radnje narudžbe za označavanje ovog odustajanja kao riješenog."

msgid "guest form"
msgstr "obrazac za goste"

msgid "admin"
msgstr "administrator"

msgid "customer account"
msgstr "korisnički račun"

msgid "Mark withdrawal as resolved"
msgstr "Označi odustajanje kao riješeno"

msgid "Submit withdrawal on behalf of customer"
msgstr "Podnesi odustajanje u ime kupca"

msgid "Withdrawals"
msgstr "Odustajanja"

msgid "Export CSV"
msgstr "Izvoz CSV"

msgid "Search"
msgstr "Pretraži"

msgid "All"
msgstr "Sve"

msgid "Pending"
msgstr "Na čekanju"

msgid "Resolved"
msgstr "Riješeno"

msgid "From"
msgstr "Od"

msgid "To"
msgstr "Do"

msgid "Filter"
msgstr "Filtriraj"

msgid "Submitted"
msgstr "Podneseno"

msgid "Source"
msgstr "Izvor"

msgid "Status"
msgstr "Status"

msgid "Mark as resolved"
msgstr "Označi kao riješeno"

msgid "Resolve"
msgstr "Riješi"

msgid "guest"
msgstr "gost"

msgid "customer"
msgstr "kupac"

#. translators: %d: number of withdrawals resolved
msgid "%d withdrawal marked as resolved."
msgid_plural "%d withdrawals marked as resolved."
msgstr[0] "%d odustajanje označeno kao riješeno."
msgstr[1] "%d odustajanja označena kao riješena."
msgstr[2] "%d odustajanja označeno kao riješeno."

msgid "You do not have permission to do this."
msgstr "Nemate dozvolu za ovu radnju."

msgid "This order does not have a pending withdrawal."
msgstr "Ova narudžba nema odustajanje na čekanju."

msgid "This withdrawal has already been resolved."
msgstr "Ovo odustajanje je već riješeno."

msgid "Guest withdrawal form"
msgstr "Obrazac za odustajanje za goste"

msgid "Enable shortcode for non-logged-in customers"
msgstr "Omogući shortcode za neprijavljene kupce"

#. translators: %s: shortcode wrapped in <code>
msgid "Place %s on any page (e.g. a public landing page). The form will ask for an order number and the billing email, then show the withdrawal form."
msgstr "Postavite %s na bilo koju stranicu (npr. javnu odredišnu stranicu). Obrazac će tražiti broj narudžbe i e-mail za naplatu, a zatim prikazati obrazac za odustajanje."
