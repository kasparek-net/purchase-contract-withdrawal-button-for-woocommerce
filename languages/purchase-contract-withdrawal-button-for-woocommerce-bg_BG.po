msgid ""
msgstr ""
"Project-Id-Version: Purchase Contract Withdrawal Button for WooCommerce 1.3.0\n"
"Report-Msgid-Bugs-To: \n"
"POT-Creation-Date: 2026-05-25 10:00+0000\n"
"PO-Revision-Date: 2026-05-29 12:00+0000\n"
"Last-Translator: Jakub Kašpárek\n"
"Language-Team: Bulgarian\n"
"Language: bg_BG\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=2; plural=(n != 1);\n"
"X-Domain: purchase-contract-withdrawal-button-for-woocommerce\n"

msgid "Purchase Contract Withdrawal Button for WooCommerce requires WooCommerce to be installed and active."
msgstr "Плъгинът Purchase Contract Withdrawal Button for WooCommerce изисква инсталиран и активен WooCommerce."

msgid "Settings"
msgstr "Настройки"

msgid "Withdraw from purchase contract"
msgstr "Откажете се от договора за покупка"

msgid "This order is no longer eligible for withdrawal (the cooling-off period has expired, or a withdrawal has already been submitted)."
msgstr "Тази поръчка вече не отговаря на условията за отказ (периодът за отказ е изтекъл или отказът вече е подаден)."

msgid "Back to order"
msgstr "Обратно към поръчката"

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email. We will be in touch with return instructions."
msgstr "Вашият отказ е подаден. Изпратихме потвърждение на имейла ви. Скоро ще се свържем с вас с инструкции за връщане."

msgid "Withdrawal has been submitted"
msgstr "Отказът е подаден"

#. translators: %s: submission date
msgid "on %s."
msgstr "на %s."

#. translators: %s: admin email address
msgid "If you have any questions, contact us at %s."
msgstr "Ако имате въпроси, свържете се с нас на %s."

msgid "You must be logged in to submit a withdrawal."
msgstr "За да подадете отказ, трябва да сте влезли в профила си."

msgid "Invalid order."
msgstr "Невалидна поръчка."

msgid "Security check failed. Please go back and try again."
msgstr "Проверката за сигурност е неуспешна. Върнете се назад и опитайте отново."

msgid "You are not authorized to access this order."
msgstr "Нямате право да достъпвате тази поръчка."

msgid "You must check the confirmation box to submit a withdrawal."
msgstr "За да подадете отказ, трябва да поставите отметка в полето за потвърждение."

msgid "This order is no longer eligible for withdrawal."
msgstr "Тази поръчка вече не отговаря на условията за отказ."

msgid "Customer submitted a withdrawal from the purchase contract."
msgstr "Клиентът подаде отказ от договора за покупка."

#. translators: %s: customer-provided reason
msgid "Reason: %s"
msgstr "Причина: %s"

#. translators: %s: bank account for refund
msgid "Refund account: %s"
msgstr "Сметка за възстановяване: %s"

msgid "Customer submitted withdrawal from purchase contract."
msgstr "Клиентът подаде отказ от договора за покупка."

msgid "Withdrawal confirmation (customer)"
msgstr "Потвърждение за отказ (клиент)"

msgid "Sent to the customer after they submit a withdrawal from a purchase contract."
msgstr "Изпраща се на клиента, след като подаде отказ от договора за покупка."

msgid "[{site_title}] Withdrawal confirmation — order #{order_number}"
msgstr "[{site_title}] Потвърждение за отказ — поръчка #{order_number}"

msgid "Withdrawal confirmation"
msgstr "Потвърждение за отказ"

msgid "If you have any questions about your withdrawal, please reply to this email."
msgstr "Ако имате въпроси относно отказа си, моля, отговорете на този имейл."

msgid "Withdrawal notification (admin)"
msgstr "Известие за отказ (администратор)"

msgid "Sent to the store administrator when a customer submits a withdrawal."
msgstr "Изпраща се на администратора на магазина, когато клиент подаде отказ."

msgid "[{site_title}] New withdrawal request — order #{order_number}"
msgstr "[{site_title}] Нова заявка за отказ — поръчка #{order_number}"

msgid "New withdrawal request"
msgstr "Нова заявка за отказ"

msgid "Enable/Disable"
msgstr "Включи/Изключи"

msgid "Enable this email notification"
msgstr "Включи това имейл известие"

msgid "Recipient(s)"
msgstr "Получатели"

#. translators: %s: admin email
msgid "Enter recipients (comma separated). Defaults to %s."
msgstr "Въведете получатели (разделени със запетая). По подразбиране: %s."

msgid "Subject"
msgstr "Тема"

msgid "Placeholders: %s"
msgstr "Заместители: %s"

msgid "Email heading"
msgstr "Заглавие на имейла"

msgid "Email type"
msgstr "Тип на имейла"

msgid "Choose which format of email to send."
msgstr "Изберете формата на изпращания имейл."

msgid "Purchase Contract Withdrawal Button for WooCommerce"
msgstr "Бутон за отказ от договор за покупка"

msgid "Withdrawal Button"
msgstr "Бутон за отказ"

#. translators: %s: WooCommerce email settings URL
msgid "Customer and admin email templates can be customized in %s."
msgstr "Шаблоните за имейл на клиенти и администратори могат да бъдат персонализирани в %s."

msgid "WooCommerce → Settings → Emails"
msgstr "WooCommerce → Настройки → Имейли"

msgid "Cooling-off period (days)"
msgstr "Период за отказ (дни)"

msgid "How long after the reference date (order completion) the withdrawal button stays visible. EU standard is 14 days."
msgstr "Колко дълго след референтната дата (завършване на поръчката) бутонът за отказ остава видим. Стандартът на ЕС е 14 дни."

msgid "Eligible order statuses"
msgstr "Допустими статуси на поръчки"

msgid "The button is shown only for orders in one of these statuses."
msgstr "Бутонът се показва само за поръчки в един от тези статуси."

msgid "Admin email recipient"
msgstr "Получател на имейл за администратор"

#. translators: %s: admin email
msgid "Leave empty to use the site admin email (%s)."
msgstr "Оставете празно, за да използвате имейла на администратора на сайта (%s)."

msgid "Status after submission"
msgstr "Статус след подаване"

msgid "Order status applied automatically after the customer submits a withdrawal."
msgstr "Статус на поръчката, прилаган автоматично след като клиент подаде отказ."

msgid "Withdrawal from purchase contract"
msgstr "Отказ от договор за покупка"

#. translators: 1: order number, 2: deadline date
msgid "Complete the form below to withdraw from purchase contract no. %1$s. The cooling-off period ends on %2$s."
msgstr "Попълнете формуляра по-долу, за да се откажете от договор за покупка №%1$s. Периодът за отказ изтича на %2$s."

msgid "Order number"
msgstr "Номер на поръчка"

msgid "Order date"
msgstr "Дата на поръчката"

msgid "Customer"
msgstr "Клиент"

msgid "Address"
msgstr "Адрес"

msgid "Email"
msgstr "Имейл"

msgid "Total"
msgstr "Общо"

msgid "Bank account for refund"
msgstr "Банкова сметка за възстановяване"

msgid "(optional — leave empty to refund to the original payment method)"
msgstr "(незадължително — оставете празно за възстановяване по първоначалния метод на плащане)"

msgid "Reason for withdrawal"
msgstr "Причина за отказ"

msgid "(optional)"
msgstr "(незадължително)"

msgid "I confirm that I am withdrawing from the purchase contract"
msgstr "Потвърждавам, че се отказвам от договора за покупка"

msgid "and I understand that I must return the purchased goods within 14 days of submitting this withdrawal. The refund will be issued after the returned goods are received."
msgstr "и разбирам, че трябва да върна закупените стоки в рамките на 14 дни от подаването на този отказ. Сумата ще бъде възстановена след получаване на върнатите стоки."

msgid "Confirm withdrawal"
msgstr "Потвърди отказа"

msgid "Cancel"
msgstr "Отказ"

msgid "Hello,"
msgstr "Здравейте,"

#. translators: 1: order number, 2: order date
msgid "We have received your withdrawal from the purchase contract for order no. %1$s placed on %2$s."
msgstr "Получихме вашия отказ от договора за покупка за поръчка №%1$s, направена на %2$s."

msgid "Next steps"
msgstr "Следващи стъпки"

msgid "Next steps:"
msgstr "Следващи стъпки:"

msgid "Please return the goods to our address within 14 days of submitting this withdrawal."
msgstr "Моля, върнете стоките на нашия адрес в рамките на 14 дни от подаването на този отказ."

msgid "We recommend shipping with tracking and insurance."
msgstr "Препоръчваме изпращане с проследяване и застраховка."

#. translators: %s: total amount
msgid "Once we receive the goods we will refund the paid amount (%s) within 14 days."
msgstr "След като получим стоките, ще възстановим платената сума (%s) в рамките на 14 дни."

msgid "A customer has submitted a withdrawal from a purchase contract."
msgstr "Клиент подаде отказ от договор за покупка."

msgid "Order"
msgstr "Поръчка"

msgid "Phone"
msgstr "Телефон"

msgid "Completion date"
msgstr "Дата на завършване"

msgid "Refund account"
msgstr "Сметка за възстановяване"

msgid "Original payment method"
msgstr "Първоначален метод на плащане"

msgid "Reason"
msgstr "Причина"

msgid "(not provided)"
msgstr "(не е посочена)"

msgid "View order:"
msgstr "Виж поръчката:"

# === 1.2.0 strings ===

msgid "A withdrawal has already been submitted for this order."
msgstr "За тази поръчка вече е подаден отказ."

msgid "an administrator"
msgstr "администратор"

msgid "Customer (guest) submitted a withdrawal from the purchase contract."
msgstr "Клиент (гост) подаде отказ от договора за покупка."

#. translators: %s: admin display name
msgid "Withdrawal marked as resolved by %s."
msgstr "Отказът е отбелязан като обработен от %s."

#. translators: %s: admin display name
msgid "Withdrawal submitted on behalf of the customer by %s."
msgstr "Отказът е подаден от името на клиента от %s."

msgid "The withdrawal form is not currently available. Please contact the store."
msgstr "Формулярът за отказ в момента не е достъпен. Моля, свържете се с магазина."

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email."
msgstr "Вашият отказ е подаден. Изпратихме потвърждение на имейла ви."

msgid "Your session has expired. Please start the lookup again."
msgstr "Сесията ви изтече. Моля, започнете търсенето отново."

msgid "Order not found."
msgstr "Поръчката не е намерена."

msgid "Order number or email is missing or invalid."
msgstr "Номерът на поръчката или имейлът липсват или са невалидни."

msgid "We could not find an order with the provided details."
msgstr "Не можахме да намерим поръчка с предоставените данни."

msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "Твърде много опити. Моля, изчакайте няколко минути и опитайте отново."

msgid "Security check failed. Please try again."
msgstr "Проверката за сигурност е неуспешна. Моля, опитайте отново."

msgid "Enter your order number and the email address used when placing the order to continue."
msgstr "За да продължите, въведете номера на поръчката и имейл адреса, използван при поръчката."

msgid "Billing email"
msgstr "Имейл за фактуриране"

msgid "Continue"
msgstr "Продължи"

msgid "Withdrawal cooling-off"
msgstr "Период за отказ"

msgid "Date of delivery"
msgstr "Дата на доставка"

msgid "Date the customer received the goods. Used as the reference date for the cooling-off period (leave empty to use the order completion date)."
msgstr "Датата, на която клиентът е получил стоките. Използва се като референтна дата за периода за отказ (оставете празно, за да се използва датата на завършване на поръчката)."

msgid "Cooling-off ends:"
msgstr "Периодът изтича:"

#. translators: %d: number of days remaining
msgid "%d day remaining"
msgid_plural "%d days remaining"
msgstr[0] "остава %d ден"
msgstr[1] "остават %d дни"

msgid "expired"
msgstr "изтекъл"

msgid "Withdrawal submitted:"
msgstr "Отказ подаден:"

msgid "Resolved:"
msgstr "Обработен:"

msgid "Use the Order actions box to mark this withdrawal as resolved."
msgstr "Използвайте полето Действия с поръчката, за да отбележите този отказ като обработен."

msgid "guest form"
msgstr "формуляр за гости"

msgid "admin"
msgstr "администратор"

msgid "customer account"
msgstr "клиентски акаунт"

msgid "Mark withdrawal as resolved"
msgstr "Отбележи отказа като обработен"

msgid "Submit withdrawal on behalf of customer"
msgstr "Подай отказ от името на клиента"

msgid "Withdrawals"
msgstr "Откази"

msgid "Export CSV"
msgstr "Експорт в CSV"

msgid "Search"
msgstr "Търсене"

msgid "All"
msgstr "Всички"

msgid "Pending"
msgstr "Чакащи"

msgid "Resolved"
msgstr "Обработени"

msgid "From"
msgstr "От"

msgid "To"
msgstr "До"

msgid "Filter"
msgstr "Филтрирай"

msgid "Submitted"
msgstr "Подаден"

msgid "Source"
msgstr "Източник"

msgid "Status"
msgstr "Статус"

msgid "Mark as resolved"
msgstr "Отбележи като обработен"

msgid "Resolve"
msgstr "Обработи"

msgid "guest"
msgstr "гост"

msgid "customer"
msgstr "клиент"

#. translators: %d: number of withdrawals resolved
msgid "%d withdrawal marked as resolved."
msgid_plural "%d withdrawals marked as resolved."
msgstr[0] "%d отказ е отбелязан като обработен."
msgstr[1] "%d отказа са отбелязани като обработени."

msgid "You do not have permission to do this."
msgstr "Нямате разрешение за това действие."

msgid "This order does not have a pending withdrawal."
msgstr "Тази поръчка няма чакащ отказ."

msgid "This withdrawal has already been resolved."
msgstr "Този отказ вече е обработен."

msgid "Guest withdrawal form"
msgstr "Формуляр за отказ за гости"

msgid "Enable shortcode for non-logged-in customers"
msgstr "Активирай шорткод за нерегистрирани клиенти"

#. translators: %s: shortcode wrapped in <code>
msgid "Place %s on any page (e.g. a public landing page). The form will ask for an order number and the billing email, then show the withdrawal form."
msgstr "Поставете %s на която и да е страница (напр. публична лендинг страница). Формулярът ще поиска номер на поръчка и имейл за фактуриране, след което ще покаже формуляра за отказ."
