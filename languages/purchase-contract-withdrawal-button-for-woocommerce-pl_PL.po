msgid ""
msgstr ""
"Project-Id-Version: Purchase Contract Withdrawal Button for WooCommerce 1.3.0\n"
"Report-Msgid-Bugs-To: \n"
"POT-Creation-Date: 2026-05-25 10:00+0000\n"
"PO-Revision-Date: 2026-05-29 12:00+0000\n"
"Last-Translator: Jakub Kašpárek\n"
"Language-Team: Polish\n"
"Language: pl_PL\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=3; plural=(n==1 ? 0 : n%10>=2 && n%10<=4 && (n%100<10 || n%100>=20) ? 1 : 2);\n"
"X-Domain: purchase-contract-withdrawal-button-for-woocommerce\n"

msgid "Purchase Contract Withdrawal Button for WooCommerce requires WooCommerce to be installed and active."
msgstr "Wtyczka Purchase Contract Withdrawal Button for WooCommerce wymaga zainstalowanej i aktywnej wtyczki WooCommerce."

msgid "Settings"
msgstr "Ustawienia"

msgid "Withdraw from purchase contract"
msgstr "Odstąp od umowy sprzedaży"

msgid "This order is no longer eligible for withdrawal (the cooling-off period has expired, or a withdrawal has already been submitted)."
msgstr "To zamówienie nie kwalifikuje się już do odstąpienia (okres na odstąpienie upłynął lub odstąpienie zostało już złożone)."

msgid "Back to order"
msgstr "Powrót do zamówienia"

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email. We will be in touch with return instructions."
msgstr "Twoje odstąpienie zostało złożone. Potwierdzenie wysłaliśmy na Twój adres e-mail. Wkrótce skontaktujemy się z instrukcjami dotyczącymi zwrotu."

msgid "Withdrawal has been submitted"
msgstr "Odstąpienie zostało złożone"

#. translators: %s: submission date
msgid "on %s."
msgstr "w dniu %s."

#. translators: %s: admin email address
msgid "If you have any questions, contact us at %s."
msgstr "W razie pytań skontaktuj się z nami pod adresem %s."

msgid "You must be logged in to submit a withdrawal."
msgstr "Aby złożyć odstąpienie, musisz być zalogowany."

msgid "Invalid order."
msgstr "Nieprawidłowe zamówienie."

msgid "Security check failed. Please go back and try again."
msgstr "Kontrola bezpieczeństwa nie powiodła się. Wróć i spróbuj ponownie."

msgid "You are not authorized to access this order."
msgstr "Nie masz uprawnień do tego zamówienia."

msgid "You must check the confirmation box to submit a withdrawal."
msgstr "Aby złożyć odstąpienie, musisz zaznaczyć pole potwierdzenia."

msgid "This order is no longer eligible for withdrawal."
msgstr "To zamówienie nie kwalifikuje się już do odstąpienia."

msgid "Customer submitted a withdrawal from the purchase contract."
msgstr "Klient złożył odstąpienie od umowy sprzedaży."

#. translators: %s: customer-provided reason
msgid "Reason: %s"
msgstr "Powód: %s"

#. translators: %s: bank account for refund
msgid "Refund account: %s"
msgstr "Konto do zwrotu: %s"

msgid "Customer submitted withdrawal from purchase contract."
msgstr "Klient złożył odstąpienie od umowy sprzedaży."

msgid "Withdrawal confirmation (customer)"
msgstr "Potwierdzenie odstąpienia (klient)"

msgid "Sent to the customer after they submit a withdrawal from a purchase contract."
msgstr "Wysyłane do klienta po złożeniu odstąpienia od umowy sprzedaży."

msgid "[{site_title}] Withdrawal confirmation — order #{order_number}"
msgstr "[{site_title}] Potwierdzenie odstąpienia — zamówienie #{order_number}"

msgid "Withdrawal confirmation"
msgstr "Potwierdzenie odstąpienia"

msgid "If you have any questions about your withdrawal, please reply to this email."
msgstr "W razie pytań dotyczących odstąpienia odpowiedz na ten e-mail."

msgid "Withdrawal notification (admin)"
msgstr "Powiadomienie o odstąpieniu (administrator)"

msgid "Sent to the store administrator when a customer submits a withdrawal."
msgstr "Wysyłane do administratora sklepu, gdy klient złoży odstąpienie."

msgid "[{site_title}] New withdrawal request — order #{order_number}"
msgstr "[{site_title}] Nowe odstąpienie — zamówienie #{order_number}"

msgid "New withdrawal request"
msgstr "Nowe odstąpienie"

msgid "Enable/Disable"
msgstr "Włącz/Wyłącz"

msgid "Enable this email notification"
msgstr "Włącz to powiadomienie e-mail"

msgid "Recipient(s)"
msgstr "Odbiorcy"

#. translators: %s: admin email
msgid "Enter recipients (comma separated). Defaults to %s."
msgstr "Wpisz odbiorców (oddzielonych przecinkami). Domyślnie: %s."

msgid "Subject"
msgstr "Temat"

msgid "Placeholders: %s"
msgstr "Symbole zastępcze: %s"

msgid "Email heading"
msgstr "Nagłówek e-maila"

msgid "Email type"
msgstr "Typ e-maila"

msgid "Choose which format of email to send."
msgstr "Wybierz format wysyłanego e-maila."

msgid "Purchase Contract Withdrawal Button for WooCommerce"
msgstr "Przycisk odstąpienia od umowy sprzedaży"

msgid "Withdrawal Button"
msgstr "Przycisk odstąpienia"

#. translators: %s: WooCommerce email settings URL
msgid "Customer and admin email templates can be customized in %s."
msgstr "Szablony e-maili dla klienta i administratora można dostosować w %s."

msgid "WooCommerce → Settings → Emails"
msgstr "WooCommerce → Ustawienia → E-maile"

msgid "Cooling-off period (days)"
msgstr "Okres na odstąpienie (dni)"

msgid "How long after the reference date (order completion) the withdrawal button stays visible. EU standard is 14 days."
msgstr "Jak długo po dacie referencyjnej (realizacji zamówienia) przycisk odstąpienia pozostaje widoczny. Standard UE to 14 dni."

msgid "Eligible order statuses"
msgstr "Kwalifikujące się statusy zamówień"

msgid "The button is shown only for orders in one of these statuses."
msgstr "Przycisk jest widoczny tylko dla zamówień w jednym z tych statusów."

msgid "Admin email recipient"
msgstr "Odbiorca e-maila administratora"

#. translators: %s: admin email
msgid "Leave empty to use the site admin email (%s)."
msgstr "Pozostaw puste, aby użyć głównego e-maila administratora (%s)."

msgid "Status after submission"
msgstr "Status po złożeniu odstąpienia"

msgid "Order status applied automatically after the customer submits a withdrawal."
msgstr "Status zamówienia ustawiany automatycznie po złożeniu odstąpienia przez klienta."

msgid "Withdrawal from purchase contract"
msgstr "Odstąpienie od umowy sprzedaży"

#. translators: 1: order number, 2: deadline date
msgid "Complete the form below to withdraw from purchase contract no. %1$s. The cooling-off period ends on %2$s."
msgstr "Wypełnij poniższy formularz, aby odstąpić od umowy sprzedaży nr %1$s. Okres na odstąpienie kończy się %2$s."

msgid "Order number"
msgstr "Numer zamówienia"

msgid "Order date"
msgstr "Data zamówienia"

msgid "Customer"
msgstr "Klient"

msgid "Address"
msgstr "Adres"

msgid "Email"
msgstr "E-mail"

msgid "Total"
msgstr "Łączna kwota"

msgid "Bank account for refund"
msgstr "Konto bankowe do zwrotu"

msgid "(optional — leave empty to refund to the original payment method)"
msgstr "(opcjonalnie — pozostaw puste, aby zwrot trafił na pierwotną metodę płatności)"

msgid "Reason for withdrawal"
msgstr "Powód odstąpienia"

msgid "(optional)"
msgstr "(opcjonalnie)"

msgid "I confirm that I am withdrawing from the purchase contract"
msgstr "Potwierdzam, że odstępuję od umowy sprzedaży"

msgid "and I understand that I must return the purchased goods within 14 days of submitting this withdrawal. The refund will be issued after the returned goods are received."
msgstr "i przyjmuję do wiadomości, że zakupiony towar muszę zwrócić w ciągu 14 dni od złożenia tego odstąpienia. Zwrot zostanie dokonany po otrzymaniu zwracanego towaru."

msgid "Confirm withdrawal"
msgstr "Potwierdź odstąpienie"

msgid "Cancel"
msgstr "Anuluj"

msgid "Hello,"
msgstr "Dzień dobry,"

#. translators: 1: order number, 2: order date
msgid "We have received your withdrawal from the purchase contract for order no. %1$s placed on %2$s."
msgstr "Potwierdzamy otrzymanie Twojego odstąpienia od umowy sprzedaży dla zamówienia nr %1$s złożonego dnia %2$s."

msgid "Next steps"
msgstr "Dalsze kroki"

msgid "Next steps:"
msgstr "Dalsze kroki:"

msgid "Please return the goods to our address within 14 days of submitting this withdrawal."
msgstr "Prosimy o odesłanie towaru na nasz adres w ciągu 14 dni od złożenia tego odstąpienia."

msgid "We recommend shipping with tracking and insurance."
msgstr "Zalecamy wysyłkę z numerem śledzenia i ubezpieczeniem."

#. translators: %s: total amount
msgid "Once we receive the goods we will refund the paid amount (%s) within 14 days."
msgstr "Po otrzymaniu towaru zwrócimy zapłaconą kwotę (%s) w ciągu 14 dni."

msgid "A customer has submitted a withdrawal from a purchase contract."
msgstr "Klient złożył odstąpienie od umowy sprzedaży."

msgid "Order"
msgstr "Zamówienie"

msgid "Phone"
msgstr "Telefon"

msgid "Completion date"
msgstr "Data realizacji"

msgid "Refund account"
msgstr "Konto do zwrotu"

msgid "Original payment method"
msgstr "Pierwotna metoda płatności"

msgid "Reason"
msgstr "Powód"

msgid "(not provided)"
msgstr "(nie podano)"

msgid "View order:"
msgstr "Zobacz zamówienie:"

# === 1.2.0 strings ===

msgid "A withdrawal has already been submitted for this order."
msgstr "Odstąpienie dla tego zamówienia zostało już złożone."

msgid "an administrator"
msgstr "administrator"

msgid "Customer (guest) submitted a withdrawal from the purchase contract."
msgstr "Klient (gość) złożył odstąpienie od umowy sprzedaży."

#. translators: %s: admin display name
msgid "Withdrawal marked as resolved by %s."
msgstr "Odstąpienie oznaczone jako rozpatrzone przez %s."

#. translators: %s: admin display name
msgid "Withdrawal submitted on behalf of the customer by %s."
msgstr "Odstąpienie złożone w imieniu klienta przez %s."

msgid "The withdrawal form is not currently available. Please contact the store."
msgstr "Formularz odstąpienia jest obecnie niedostępny. Skontaktuj się ze sklepem."

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email."
msgstr "Twoje odstąpienie zostało złożone. Potwierdzenie wysłaliśmy na Twój adres e-mail."

msgid "Your session has expired. Please start the lookup again."
msgstr "Twoja sesja wygasła. Rozpocznij wyszukiwanie ponownie."

msgid "Order not found."
msgstr "Nie znaleziono zamówienia."

msgid "Order number or email is missing or invalid."
msgstr "Numer zamówienia lub e-mail jest brakujący lub nieprawidłowy."

msgid "We could not find an order with the provided details."
msgstr "Nie udało się znaleźć zamówienia z podanymi danymi."

msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "Zbyt wiele prób. Poczekaj kilka minut i spróbuj ponownie."

msgid "Security check failed. Please try again."
msgstr "Kontrola bezpieczeństwa nie powiodła się. Spróbuj ponownie."

msgid "Enter your order number and the email address used when placing the order to continue."
msgstr "Aby kontynuować, wpisz numer zamówienia i adres e-mail użyty podczas składania zamówienia."

msgid "Billing email"
msgstr "E-mail z danych rozliczeniowych"

msgid "Continue"
msgstr "Kontynuuj"

msgid "Withdrawal cooling-off"
msgstr "Okres na odstąpienie"

msgid "Date of delivery"
msgstr "Data dostawy"

msgid "Date the customer received the goods. Used as the reference date for the cooling-off period (leave empty to use the order completion date)."
msgstr "Data, w której klient otrzymał towar. Używana jako data referencyjna dla okresu na odstąpienie (pozostaw puste, aby użyć daty realizacji zamówienia)."

msgid "Cooling-off ends:"
msgstr "Okres kończy się:"

#. translators: %d: number of days remaining
msgid "%d day remaining"
msgid_plural "%d days remaining"
msgstr[0] "pozostał %d dzień"
msgstr[1] "pozostały %d dni"
msgstr[2] "pozostało %d dni"

msgid "expired"
msgstr "upłynął"

msgid "Withdrawal submitted:"
msgstr "Odstąpienie złożone:"

msgid "Resolved:"
msgstr "Rozpatrzone:"

msgid "Use the Order actions box to mark this withdrawal as resolved."
msgstr "Użyj sekcji Akcje zamówienia, aby oznaczyć odstąpienie jako rozpatrzone."

msgid "guest form"
msgstr "formularz gościa"

msgid "admin"
msgstr "administrator"

msgid "customer account"
msgstr "konto klienta"

msgid "Mark withdrawal as resolved"
msgstr "Oznacz odstąpienie jako rozpatrzone"

msgid "Submit withdrawal on behalf of customer"
msgstr "Złóż odstąpienie w imieniu klienta"

msgid "Withdrawals"
msgstr "Odstąpienia"

msgid "Export CSV"
msgstr "Eksport CSV"

msgid "Search"
msgstr "Szukaj"

msgid "All"
msgstr "Wszystkie"

msgid "Pending"
msgstr "Oczekujące"

msgid "Resolved"
msgstr "Rozpatrzone"

msgid "From"
msgstr "Od"

msgid "To"
msgstr "Do"

msgid "Filter"
msgstr "Filtruj"

msgid "Submitted"
msgstr "Złożone"

msgid "Source"
msgstr "Źródło"

msgid "Status"
msgstr "Status"

msgid "Mark as resolved"
msgstr "Oznacz jako rozpatrzone"

msgid "Resolve"
msgstr "Rozpatrz"

msgid "guest"
msgstr "gość"

msgid "customer"
msgstr "klient"

#. translators: %d: number of withdrawals resolved
msgid "%d withdrawal marked as resolved."
msgid_plural "%d withdrawals marked as resolved."
msgstr[0] "%d odstąpienie oznaczone jako rozpatrzone."
msgstr[1] "%d odstąpienia oznaczone jako rozpatrzone."
msgstr[2] "%d odstąpień oznaczonych jako rozpatrzone."

msgid "You do not have permission to do this."
msgstr "Nie masz uprawnień do wykonania tej akcji."

msgid "This order does not have a pending withdrawal."
msgstr "To zamówienie nie ma oczekującego odstąpienia."

msgid "This withdrawal has already been resolved."
msgstr "To odstąpienie zostało już rozpatrzone."

msgid "Guest withdrawal form"
msgstr "Formularz odstąpienia dla gości"

msgid "Enable shortcode for non-logged-in customers"
msgstr "Włącz shortcode dla niezalogowanych klientów"

#. translators: %s: shortcode wrapped in <code>
msgid "Place %s on any page (e.g. a public landing page). The form will ask for an order number and the billing email, then show the withdrawal form."
msgstr "Umieść %s na dowolnej stronie (np. publicznej landing page). Formularz poprosi o numer zamówienia i e-mail z danych rozliczeniowych, a następnie wyświetli formularz odstąpienia."
