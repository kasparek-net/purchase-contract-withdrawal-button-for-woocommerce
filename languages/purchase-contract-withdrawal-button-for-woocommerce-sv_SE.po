msgid ""
msgstr ""
"Project-Id-Version: Purchase Contract Withdrawal Button for WooCommerce 1.3.0\n"
"Report-Msgid-Bugs-To: \n"
"POT-Creation-Date: 2026-05-25 10:00+0000\n"
"PO-Revision-Date: 2026-05-29 12:00+0000\n"
"Last-Translator: Jakub Kašpárek\n"
"Language-Team: Swedish\n"
"Language: sv_SE\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=2; plural=(n != 1);\n"
"X-Domain: purchase-contract-withdrawal-button-for-woocommerce\n"

msgid "Purchase Contract Withdrawal Button for WooCommerce requires WooCommerce to be installed and active."
msgstr "Purchase Contract Withdrawal Button for WooCommerce kräver att WooCommerce är installerat och aktivt."

msgid "Settings"
msgstr "Inställningar"

msgid "Withdraw from purchase contract"
msgstr "Frånträd köpeavtalet"

msgid "This order is no longer eligible for withdrawal (the cooling-off period has expired, or a withdrawal has already been submitted)."
msgstr "Denna beställning kan inte längre frånträdas (ångerfristen har löpt ut eller en ångeranmälan har redan lämnats in)."

msgid "Back to order"
msgstr "Tillbaka till beställningen"

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email. We will be in touch with return instructions."
msgstr "Din ångeranmälan har skickats in. En bekräftelse har skickats till din e-post. Vi återkommer med returinstruktioner."

msgid "Withdrawal has been submitted"
msgstr "Ångeranmälan har skickats in"

#. translators: %s: submission date
msgid "on %s."
msgstr "den %s."

#. translators: %s: admin email address
msgid "If you have any questions, contact us at %s."
msgstr "Om du har frågor, kontakta oss på %s."

msgid "You must be logged in to submit a withdrawal."
msgstr "Du måste vara inloggad för att lämna en ångeranmälan."

msgid "Invalid order."
msgstr "Ogiltig beställning."

msgid "Security check failed. Please go back and try again."
msgstr "Säkerhetskontrollen misslyckades. Gå tillbaka och försök igen."

msgid "You are not authorized to access this order."
msgstr "Du har inte behörighet till denna beställning."

msgid "You must check the confirmation box to submit a withdrawal."
msgstr "Du måste kryssa i bekräftelserutan för att skicka in en ångeranmälan."

msgid "This order is no longer eligible for withdrawal."
msgstr "Denna beställning kan inte längre frånträdas."

msgid "Customer submitted a withdrawal from the purchase contract."
msgstr "Kunden har lämnat en ångeranmälan för köpeavtalet."

#. translators: %s: customer-provided reason
msgid "Reason: %s"
msgstr "Orsak: %s"

#. translators: %s: bank account for refund
msgid "Refund account: %s"
msgstr "Konto för återbetalning: %s"

msgid "Customer submitted withdrawal from purchase contract."
msgstr "Kunden har lämnat in en ångeranmälan för köpeavtalet."

msgid "Withdrawal confirmation (customer)"
msgstr "Bekräftelse av ångerrätt (kund)"

msgid "Sent to the customer after they submit a withdrawal from a purchase contract."
msgstr "Skickas till kunden efter att en ångeranmälan för ett köpeavtal har lämnats in."

msgid "[{site_title}] Withdrawal confirmation — order #{order_number}"
msgstr "[{site_title}] Bekräftelse av ångerrätt — beställning #{order_number}"

msgid "Withdrawal confirmation"
msgstr "Bekräftelse av ångerrätt"

msgid "If you have any questions about your withdrawal, please reply to this email."
msgstr "Om du har frågor om din ångeranmälan, svara gärna på detta e-postmeddelande."

msgid "Withdrawal notification (admin)"
msgstr "Avisering om ångeranmälan (admin)"

msgid "Sent to the store administrator when a customer submits a withdrawal."
msgstr "Skickas till butikens administratör när en kund lämnar en ångeranmälan."

msgid "[{site_title}] New withdrawal request — order #{order_number}"
msgstr "[{site_title}] Ny ångeranmälan — beställning #{order_number}"

msgid "New withdrawal request"
msgstr "Ny ångeranmälan"

msgid "Enable/Disable"
msgstr "Aktivera/inaktivera"

msgid "Enable this email notification"
msgstr "Aktivera denna e-postavisering"

msgid "Recipient(s)"
msgstr "Mottagare"

#. translators: %s: admin email
msgid "Enter recipients (comma separated). Defaults to %s."
msgstr "Ange mottagare (kommaseparerade). Standardvärde: %s."

msgid "Subject"
msgstr "Ämne"

msgid "Placeholders: %s"
msgstr "Platshållare: %s"

msgid "Email heading"
msgstr "Rubrik på e-post"

msgid "Email type"
msgstr "E-posttyp"

msgid "Choose which format of email to send."
msgstr "Välj vilket format e-postmeddelandet ska skickas i."

msgid "Purchase Contract Withdrawal Button for WooCommerce"
msgstr "Ångerknapp för köpeavtal"

msgid "Withdrawal Button"
msgstr "Ångerknapp"

#. translators: %s: WooCommerce email settings URL
msgid "Customer and admin email templates can be customized in %s."
msgstr "Mallar för kund- och adminmail kan anpassas i %s."

msgid "WooCommerce → Settings → Emails"
msgstr "WooCommerce → Inställningar → E-post"

msgid "Cooling-off period (days)"
msgstr "Ångerfrist (dagar)"

msgid "How long after the reference date (order completion) the withdrawal button stays visible. EU standard is 14 days."
msgstr "Hur länge efter referensdatumet (beställning slutförd) ångerknappen är synlig. EU-standard är 14 dagar."

msgid "Eligible order statuses"
msgstr "Berättigade beställningsstatusar"

msgid "The button is shown only for orders in one of these statuses."
msgstr "Knappen visas endast för beställningar med någon av dessa statusar."

msgid "Admin email recipient"
msgstr "Mottagare av adminmail"

#. translators: %s: admin email
msgid "Leave empty to use the site admin email (%s)."
msgstr "Lämna tomt för att använda webbplatsens administratörs-e-post (%s)."

msgid "Status after submission"
msgstr "Status efter inlämning"

msgid "Order status applied automatically after the customer submits a withdrawal."
msgstr "Beställningsstatus som tilldelas automatiskt efter att kunden lämnat en ångeranmälan."

msgid "Withdrawal from purchase contract"
msgstr "Frånträdande av köpeavtalet"

#. translators: 1: order number, 2: deadline date
msgid "Complete the form below to withdraw from purchase contract no. %1$s. The cooling-off period ends on %2$s."
msgstr "Fyll i formuläret nedan för att frånträda köpeavtal nr %1$s. Ångerfristen löper ut den %2$s."

msgid "Order number"
msgstr "Beställningsnummer"

msgid "Order date"
msgstr "Beställningsdatum"

msgid "Customer"
msgstr "Kund"

msgid "Address"
msgstr "Adress"

msgid "Email"
msgstr "E-post"

msgid "Total"
msgstr "Totalt"

msgid "Bank account for refund"
msgstr "Bankkonto för återbetalning"

msgid "(optional — leave empty to refund to the original payment method)"
msgstr "(valfritt — lämna tomt för att återbetala till ursprunglig betalningsmetod)"

msgid "Reason for withdrawal"
msgstr "Skäl för ångerrätt"

msgid "(optional)"
msgstr "(valfritt)"

msgid "I confirm that I am withdrawing from the purchase contract"
msgstr "Jag bekräftar att jag frånträder köpeavtalet"

msgid "and I understand that I must return the purchased goods within 14 days of submitting this withdrawal. The refund will be issued after the returned goods are received."
msgstr "och jag förstår att jag måste återlämna de köpta varorna inom 14 dagar från att denna ångeranmälan lämnats in. Återbetalningen sker efter att de returnerade varorna mottagits."

msgid "Confirm withdrawal"
msgstr "Bekräfta ångeranmälan"

msgid "Cancel"
msgstr "Avbryt"

msgid "Hello,"
msgstr "Hej,"

#. translators: 1: order number, 2: order date
msgid "We have received your withdrawal from the purchase contract for order no. %1$s placed on %2$s."
msgstr "Vi har mottagit din ångeranmälan för köpeavtalet avseende beställning nr %1$s, lagd den %2$s."

msgid "Next steps"
msgstr "Nästa steg"

msgid "Next steps:"
msgstr "Nästa steg:"

msgid "Please return the goods to our address within 14 days of submitting this withdrawal."
msgstr "Skicka tillbaka varorna till vår adress inom 14 dagar från att denna ångeranmälan lämnats in."

msgid "We recommend shipping with tracking and insurance."
msgstr "Vi rekommenderar att skicka med spårning och försäkring."

#. translators: %s: total amount
msgid "Once we receive the goods we will refund the paid amount (%s) within 14 days."
msgstr "Så snart vi mottagit varorna återbetalar vi det betalade beloppet (%s) inom 14 dagar."

msgid "A customer has submitted a withdrawal from a purchase contract."
msgstr "En kund har lämnat in en ångeranmälan för ett köpeavtal."

msgid "Order"
msgstr "Beställning"

msgid "Phone"
msgstr "Telefon"

msgid "Completion date"
msgstr "Slutförandedatum"

msgid "Refund account"
msgstr "Konto för återbetalning"

msgid "Original payment method"
msgstr "Ursprunglig betalningsmetod"

msgid "Reason"
msgstr "Orsak"

msgid "(not provided)"
msgstr "(ej angivet)"

msgid "View order:"
msgstr "Visa beställning:"

# === 1.2.0 strings ===

msgid "A withdrawal has already been submitted for this order."
msgstr "En ångeranmälan har redan lämnats in för denna beställning."

msgid "an administrator"
msgstr "en administratör"

msgid "Customer (guest) submitted a withdrawal from the purchase contract."
msgstr "Kund (gäst) har lämnat in en ångeranmälan för köpeavtalet."

#. translators: %s: admin display name
msgid "Withdrawal marked as resolved by %s."
msgstr "Ångeranmälan markerad som hanterad av %s."

#. translators: %s: admin display name
msgid "Withdrawal submitted on behalf of the customer by %s."
msgstr "Ångeranmälan inlämnad å kundens vägnar av %s."

msgid "The withdrawal form is not currently available. Please contact the store."
msgstr "Ångerformuläret är för närvarande inte tillgängligt. Kontakta butiken."

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email."
msgstr "Din ångeranmälan har skickats in. En bekräftelse har skickats till din e-post."

msgid "Your session has expired. Please start the lookup again."
msgstr "Din session har gått ut. Börja sökningen från början."

msgid "Order not found."
msgstr "Beställningen hittades inte."

msgid "Order number or email is missing or invalid."
msgstr "Beställningsnummer eller e-postadress saknas eller är ogiltigt."

msgid "We could not find an order with the provided details."
msgstr "Vi kunde inte hitta någon beställning med de angivna uppgifterna."

msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "För många försök. Vänta några minuter och försök igen."

msgid "Security check failed. Please try again."
msgstr "Säkerhetskontrollen misslyckades. Försök igen."

msgid "Enter your order number and the email address used when placing the order to continue."
msgstr "Ange ditt beställningsnummer och den e-postadress som användes vid beställningen för att fortsätta."

msgid "Billing email"
msgstr "Fakturerings-e-post"

msgid "Continue"
msgstr "Fortsätt"

msgid "Withdrawal cooling-off"
msgstr "Ångerfrist"

msgid "Date of delivery"
msgstr "Leveransdatum"

msgid "Date the customer received the goods. Used as the reference date for the cooling-off period (leave empty to use the order completion date)."
msgstr "Datum då kunden mottog varorna. Används som referensdatum för ångerfristen (lämna tomt för att använda datumet då beställningen slutfördes)."

msgid "Cooling-off ends:"
msgstr "Ångerfrist löper ut:"

#. translators: %d: number of days remaining
msgid "%d day remaining"
msgid_plural "%d days remaining"
msgstr[0] "%d dag kvar"
msgstr[1] "%d dagar kvar"

msgid "expired"
msgstr "utlöpt"

msgid "Withdrawal submitted:"
msgstr "Ångeranmälan inlämnad:"

msgid "Resolved:"
msgstr "Hanterad:"

msgid "Use the Order actions box to mark this withdrawal as resolved."
msgstr "Använd rutan Beställningsåtgärder för att markera denna ångeranmälan som hanterad."

msgid "guest form"
msgstr "gästformulär"

msgid "admin"
msgstr "admin"

msgid "customer account"
msgstr "kundkonto"

msgid "Mark withdrawal as resolved"
msgstr "Markera ångeranmälan som hanterad"

msgid "Submit withdrawal on behalf of customer"
msgstr "Lämna in ångeranmälan å kundens vägnar"

msgid "Withdrawals"
msgstr "Ångeranmälningar"

msgid "Export CSV"
msgstr "Exportera CSV"

msgid "Search"
msgstr "Sök"

msgid "All"
msgstr "Alla"

msgid "Pending"
msgstr "Väntande"

msgid "Resolved"
msgstr "Hanterade"

msgid "From"
msgstr "Från"

msgid "To"
msgstr "Till"

msgid "Filter"
msgstr "Filtrera"

msgid "Submitted"
msgstr "Inlämnad"

msgid "Source"
msgstr "Källa"

msgid "Status"
msgstr "Status"

msgid "Mark as resolved"
msgstr "Markera som hanterad"

msgid "Resolve"
msgstr "Hantera"

msgid "guest"
msgstr "gäst"

msgid "customer"
msgstr "kund"

#. translators: %d: number of withdrawals resolved
msgid "%d withdrawal marked as resolved."
msgid_plural "%d withdrawals marked as resolved."
msgstr[0] "%d ångeranmälan markerad som hanterad."
msgstr[1] "%d ångeranmälningar markerade som hanterade."

msgid "You do not have permission to do this."
msgstr "Du har inte behörighet att göra detta."

msgid "This order does not have a pending withdrawal."
msgstr "Denna beställning har ingen väntande ångeranmälan."

msgid "This withdrawal has already been resolved."
msgstr "Denna ångeranmälan är redan hanterad."

msgid "Guest withdrawal form"
msgstr "Ångerformulär för gäster"

msgid "Enable shortcode for non-logged-in customers"
msgstr "Aktivera shortcode för icke inloggade kunder"

#. translators: %s: shortcode wrapped in <code>
msgid "Place %s on any page (e.g. a public landing page). The form will ask for an order number and the billing email, then show the withdrawal form."
msgstr "Placera %s på valfri sida (t.ex. en publik landningssida). Formuläret frågar efter beställningsnummer och fakturerings-e-post och visar sedan ångerformuläret."
