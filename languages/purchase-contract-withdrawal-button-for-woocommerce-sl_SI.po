msgid ""
msgstr ""
"Project-Id-Version: Purchase Contract Withdrawal Button for WooCommerce 1.3.0\n"
"Report-Msgid-Bugs-To: \n"
"POT-Creation-Date: 2026-05-25 10:00+0000\n"
"PO-Revision-Date: 2026-05-29 12:00+0000\n"
"Last-Translator: Jakub Kašpárek\n"
"Language-Team: Slovenian\n"
"Language: sl_SI\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=4; plural=(n%100==1 ? 0 : n%100==2 ? 1 : n%100==3 || n%100==4 ? 2 : 3);\n"
"X-Domain: purchase-contract-withdrawal-button-for-woocommerce\n"

msgid "Purchase Contract Withdrawal Button for WooCommerce requires WooCommerce to be installed and active."
msgstr "Vtičnik Purchase Contract Withdrawal Button for WooCommerce zahteva nameščen in aktiven WooCommerce."

msgid "Settings"
msgstr "Nastavitve"

msgid "Withdraw from purchase contract"
msgstr "Odstopi od kupoprodajne pogodbe"

msgid "This order is no longer eligible for withdrawal (the cooling-off period has expired, or a withdrawal has already been submitted)."
msgstr "Za to naročilo odstop ni več mogoč (odstopni rok je potekel ali pa je odstop že bil oddan)."

msgid "Back to order"
msgstr "Nazaj na naročilo"

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email. We will be in touch with return instructions."
msgstr "Vaš odstop od pogodbe je bil uspešno oddan. Potrditev smo poslali na vaš e-poštni naslov. Kmalu vam bomo poslali navodila za vračilo blaga."

msgid "Withdrawal has been submitted"
msgstr "Odstop od pogodbe je bil oddan"

#. translators: %s: submission date
msgid "on %s."
msgstr "dne %s."

#. translators: %s: admin email address
msgid "If you have any questions, contact us at %s."
msgstr "Če imate vprašanja, nas kontaktirajte na %s."

msgid "You must be logged in to submit a withdrawal."
msgstr "Za oddajo odstopa morate biti prijavljeni."

msgid "Invalid order."
msgstr "Neveljavno naročilo."

msgid "Security check failed. Please go back and try again."
msgstr "Varnostno preverjanje ni uspelo. Vrnite se in poskusite znova."

msgid "You are not authorized to access this order."
msgstr "Nimate pooblastila za dostop do tega naročila."

msgid "You must check the confirmation box to submit a withdrawal."
msgstr "Za oddajo odstopa morate označiti potrditveno polje."

msgid "This order is no longer eligible for withdrawal."
msgstr "Za to naročilo odstop ni več mogoč."

msgid "Customer submitted a withdrawal from the purchase contract."
msgstr "Kupec je oddal odstop od kupoprodajne pogodbe."

#. translators: %s: customer-provided reason
msgid "Reason: %s"
msgstr "Razlog: %s"

#. translators: %s: bank account for refund
msgid "Refund account: %s"
msgstr "Račun za vračilo: %s"

msgid "Customer submitted withdrawal from purchase contract."
msgstr "Kupec je oddal odstop od kupoprodajne pogodbe."

msgid "Withdrawal confirmation (customer)"
msgstr "Potrditev odstopa (kupec)"

msgid "Sent to the customer after they submit a withdrawal from a purchase contract."
msgstr "Poslano kupcu po oddaji odstopa od kupoprodajne pogodbe."

msgid "[{site_title}] Withdrawal confirmation — order #{order_number}"
msgstr "[{site_title}] Potrditev odstopa — naročilo #{order_number}"

msgid "Withdrawal confirmation"
msgstr "Potrditev odstopa"

msgid "If you have any questions about your withdrawal, please reply to this email."
msgstr "Če imate vprašanja glede vašega odstopa, odgovorite na to e-pošto."

msgid "Withdrawal notification (admin)"
msgstr "Obvestilo o odstopu (skrbnik)"

msgid "Sent to the store administrator when a customer submits a withdrawal."
msgstr "Poslano skrbniku trgovine, ko kupec odda odstop."

msgid "[{site_title}] New withdrawal request — order #{order_number}"
msgstr "[{site_title}] Nova zahteva za odstop — naročilo #{order_number}"

msgid "New withdrawal request"
msgstr "Nova zahteva za odstop"

msgid "Enable/Disable"
msgstr "Omogoči/Onemogoči"

msgid "Enable this email notification"
msgstr "Omogoči to e-poštno obvestilo"

msgid "Recipient(s)"
msgstr "Prejemnik(i)"

#. translators: %s: admin email
msgid "Enter recipients (comma separated). Defaults to %s."
msgstr "Vnesite prejemnike (ločene z vejico). Privzeto: %s."

msgid "Subject"
msgstr "Zadeva"

msgid "Placeholders: %s"
msgstr "Ograde: %s"

msgid "Email heading"
msgstr "Naslov e-pošte"

msgid "Email type"
msgstr "Vrsta e-pošte"

msgid "Choose which format of email to send."
msgstr "Izberite format e-pošte za pošiljanje."

msgid "Purchase Contract Withdrawal Button for WooCommerce"
msgstr "Gumb za odstop od kupoprodajne pogodbe"

msgid "Withdrawal Button"
msgstr "Gumb za odstop"

#. translators: %s: WooCommerce email settings URL
msgid "Customer and admin email templates can be customized in %s."
msgstr "Predloge e-pošte za kupce in skrbnike lahko prilagodite v %s."

msgid "WooCommerce → Settings → Emails"
msgstr "WooCommerce → Nastavitve → E-pošta"

msgid "Cooling-off period (days)"
msgstr "Odstopni rok (dni)"

msgid "How long after the reference date (order completion) the withdrawal button stays visible. EU standard is 14 days."
msgstr "Kako dolgo po referenčnem datumu (zaključek naročila) ostane gumb za odstop viden. Standard EU je 14 dni."

msgid "Eligible order statuses"
msgstr "Upravičena stanja naročil"

msgid "The button is shown only for orders in one of these statuses."
msgstr "Gumb je prikazan samo za naročila v enem od teh stanj."

msgid "Admin email recipient"
msgstr "Prejemnik skrbniške e-pošte"

#. translators: %s: admin email
msgid "Leave empty to use the site admin email (%s)."
msgstr "Pustite prazno za uporabo skrbniške e-pošte spletnega mesta (%s)."

msgid "Status after submission"
msgstr "Stanje po oddaji"

msgid "Order status applied automatically after the customer submits a withdrawal."
msgstr "Stanje naročila, ki se samodejno uporabi po oddaji odstopa s strani kupca."

msgid "Withdrawal from purchase contract"
msgstr "Odstop od kupoprodajne pogodbe"

#. translators: 1: order number, 2: deadline date
msgid "Complete the form below to withdraw from purchase contract no. %1$s. The cooling-off period ends on %2$s."
msgstr "Izpolnite spodnji obrazec za odstop od kupoprodajne pogodbe št. %1$s. Odstopni rok poteče %2$s."

msgid "Order number"
msgstr "Številka naročila"

msgid "Order date"
msgstr "Datum naročila"

msgid "Customer"
msgstr "Kupec"

msgid "Address"
msgstr "Naslov"

msgid "Email"
msgstr "E-pošta"

msgid "Total"
msgstr "Skupaj"

msgid "Bank account for refund"
msgstr "Bančni račun za vračilo denarja"

msgid "(optional — leave empty to refund to the original payment method)"
msgstr "(izbirno — pustite prazno za vračilo na izvirno plačilno metodo)"

msgid "Reason for withdrawal"
msgstr "Razlog za odstop"

msgid "(optional)"
msgstr "(izbirno)"

msgid "I confirm that I am withdrawing from the purchase contract"
msgstr "Potrjujem, da odstopam od kupoprodajne pogodbe"

msgid "and I understand that I must return the purchased goods within 14 days of submitting this withdrawal. The refund will be issued after the returned goods are received."
msgstr "in razumem, da moram kupljeno blago vrniti v 14 dneh od oddaje tega odstopa. Vračilo denarja bo izvedeno po prejemu vrnjenega blaga."

msgid "Confirm withdrawal"
msgstr "Potrdi odstop"

msgid "Cancel"
msgstr "Prekliči"

msgid "Hello,"
msgstr "Pozdravljeni,"

#. translators: 1: order number, 2: order date
msgid "We have received your withdrawal from the purchase contract for order no. %1$s placed on %2$s."
msgstr "Prejeli smo vaš odstop od kupoprodajne pogodbe za naročilo št. %1$s z dne %2$s."

msgid "Next steps"
msgstr "Naslednji koraki"

msgid "Next steps:"
msgstr "Naslednji koraki:"

msgid "Please return the goods to our address within 14 days of submitting this withdrawal."
msgstr "Prosimo, vrnite blago na naš naslov v 14 dneh od oddaje tega odstopa."

msgid "We recommend shipping with tracking and insurance."
msgstr "Priporočamo pošiljanje s sledenjem in zavarovanjem."

#. translators: %s: total amount
msgid "Once we receive the goods we will refund the paid amount (%s) within 14 days."
msgstr "Po prejemu blaga vam bomo plačani znesek (%s) povrnili v 14 dneh."

msgid "A customer has submitted a withdrawal from a purchase contract."
msgstr "Kupec je oddal odstop od kupoprodajne pogodbe."

msgid "Order"
msgstr "Naročilo"

msgid "Phone"
msgstr "Telefon"

msgid "Completion date"
msgstr "Datum zaključka"

msgid "Refund account"
msgstr "Račun za vračilo"

msgid "Original payment method"
msgstr "Izvirna plačilna metoda"

msgid "Reason"
msgstr "Razlog"

msgid "(not provided)"
msgstr "(ni naveden)"

msgid "View order:"
msgstr "Ogled naročila:"

# === 1.2.0 strings ===

msgid "A withdrawal has already been submitted for this order."
msgstr "Za to naročilo je bil odstop že oddan."

msgid "an administrator"
msgstr "skrbnik"

msgid "Customer (guest) submitted a withdrawal from the purchase contract."
msgstr "Kupec (gost) je oddal odstop od kupoprodajne pogodbe."

#. translators: %s: admin display name
msgid "Withdrawal marked as resolved by %s."
msgstr "Odstop je označil kot rešen %s."

#. translators: %s: admin display name
msgid "Withdrawal submitted on behalf of the customer by %s."
msgstr "Odstop je v imenu kupca oddal %s."

msgid "The withdrawal form is not currently available. Please contact the store."
msgstr "Obrazec za odstop trenutno ni na voljo. Prosimo, kontaktirajte trgovino."

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email."
msgstr "Vaš odstop je bil oddan. Potrditev smo poslali na vaš e-poštni naslov."

msgid "Your session has expired. Please start the lookup again."
msgstr "Vaša seja je potekla. Prosimo, znova začnite iskanje."

msgid "Order not found."
msgstr "Naročilo ni bilo najdeno."

msgid "Order number or email is missing or invalid."
msgstr "Številka naročila ali e-pošta manjka oziroma je neveljavna."

msgid "We could not find an order with the provided details."
msgstr "Naročila z navedenimi podatki nismo mogli najti."

msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "Preveč poskusov. Počakajte nekaj minut in poskusite znova."

msgid "Security check failed. Please try again."
msgstr "Varnostno preverjanje ni uspelo. Prosimo, poskusite znova."

msgid "Enter your order number and the email address used when placing the order to continue."
msgstr "Za nadaljevanje vnesite številko naročila in e-poštni naslov, ki ste ga uporabili pri naročanju."

msgid "Billing email"
msgstr "E-pošta za obračun"

msgid "Continue"
msgstr "Nadaljuj"

msgid "Withdrawal cooling-off"
msgstr "Odstopni rok"

msgid "Date of delivery"
msgstr "Datum dostave"

msgid "Date the customer received the goods. Used as the reference date for the cooling-off period (leave empty to use the order completion date)."
msgstr "Datum, ko je kupec prejel blago. Uporablja se kot referenčni datum za odstopni rok (pustite prazno za uporabo datuma zaključka naročila)."

msgid "Cooling-off ends:"
msgstr "Odstopni rok poteče:"

#. translators: %d: number of days remaining
msgid "%d day remaining"
msgid_plural "%d days remaining"
msgstr[0] "preostane %d dan"
msgstr[1] "preostaneta %d dneva"
msgstr[2] "preostanejo %d dnevi"
msgstr[3] "preostane %d dni"

msgid "expired"
msgstr "potekel"

msgid "Withdrawal submitted:"
msgstr "Odstop oddan:"

msgid "Resolved:"
msgstr "Rešeno:"

msgid "Use the Order actions box to mark this withdrawal as resolved."
msgstr "Uporabite okno Dejanja naročila za označitev tega odstopa kot rešenega."

msgid "guest form"
msgstr "obrazec za goste"

msgid "admin"
msgstr "skrbnik"

msgid "customer account"
msgstr "kupčev račun"

msgid "Mark withdrawal as resolved"
msgstr "Označi odstop kot rešen"

msgid "Submit withdrawal on behalf of customer"
msgstr "Oddaj odstop v imenu kupca"

msgid "Withdrawals"
msgstr "Odstopi"

msgid "Export CSV"
msgstr "Izvoz CSV"

msgid "Search"
msgstr "Iskanje"

msgid "All"
msgstr "Vsi"

msgid "Pending"
msgstr "V čakanju"

msgid "Resolved"
msgstr "Rešeno"

msgid "From"
msgstr "Od"

msgid "To"
msgstr "Do"

msgid "Filter"
msgstr "Filtriraj"

msgid "Submitted"
msgstr "Oddano"

msgid "Source"
msgstr "Vir"

msgid "Status"
msgstr "Stanje"

msgid "Mark as resolved"
msgstr "Označi kot rešeno"

msgid "Resolve"
msgstr "Reši"

msgid "guest"
msgstr "gost"

msgid "customer"
msgstr "kupec"

#. translators: %d: number of withdrawals resolved
msgid "%d withdrawal marked as resolved."
msgid_plural "%d withdrawals marked as resolved."
msgstr[0] "%d odstop označen kot rešen."
msgstr[1] "%d odstopa označena kot rešena."
msgstr[2] "%d odstopi označeni kot rešeni."
msgstr[3] "%d odstopov označenih kot rešenih."

msgid "You do not have permission to do this."
msgstr "Za to nimate dovoljenja."

msgid "This order does not have a pending withdrawal."
msgstr "To naročilo nima nerešenega odstopa."

msgid "This withdrawal has already been resolved."
msgstr "Ta odstop je že bil rešen."

msgid "Guest withdrawal form"
msgstr "Obrazec za odstop za goste"

msgid "Enable shortcode for non-logged-in customers"
msgstr "Omogoči kratko kodo za neprijavljene kupce"

#. translators: %s: shortcode wrapped in <code>
msgid "Place %s on any page (e.g. a public landing page). The form will ask for an order number and the billing email, then show the withdrawal form."
msgstr "Postavite %s na poljubno stran (npr. javno pristajalno stran). Obrazec bo kupca vprašal po številki naročila in e-pošti za obračun ter nato prikazal obrazec za odstop."
