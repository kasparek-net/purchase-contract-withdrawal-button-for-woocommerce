msgid ""
msgstr ""
"Project-Id-Version: Purchase Contract Withdrawal Button for WooCommerce 1.3.0\n"
"Report-Msgid-Bugs-To: \n"
"POT-Creation-Date: 2026-05-25 10:00+0000\n"
"PO-Revision-Date: 2026-05-29 12:00+0000\n"
"Last-Translator: Jakub Kašpárek\n"
"Language-Team: Spanish\n"
"Language: es_ES\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=2; plural=(n != 1);\n"
"X-Domain: purchase-contract-withdrawal-button-for-woocommerce\n"

msgid "Purchase Contract Withdrawal Button for WooCommerce requires WooCommerce to be installed and active."
msgstr "El plugin Purchase Contract Withdrawal Button for WooCommerce requiere que WooCommerce esté instalado y activo."

msgid "Settings"
msgstr "Ajustes"

msgid "Withdraw from purchase contract"
msgstr "Desistir del contrato de compra"

msgid "This order is no longer eligible for withdrawal (the cooling-off period has expired, or a withdrawal has already been submitted)."
msgstr "Este pedido ya no admite desistimiento (el plazo de desistimiento ha vencido o ya se ha presentado un desistimiento)."

msgid "Back to order"
msgstr "Volver al pedido"

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email. We will be in touch with return instructions."
msgstr "Su desistimiento se ha enviado correctamente. Hemos enviado una confirmación a su correo electrónico. Nos pondremos en contacto con las instrucciones para la devolución."

msgid "Withdrawal has been submitted"
msgstr "El desistimiento se ha enviado"

#. translators: %s: submission date
msgid "on %s."
msgstr "el %s."

#. translators: %s: admin email address
msgid "If you have any questions, contact us at %s."
msgstr "Si tiene alguna pregunta, contáctenos en %s."

msgid "You must be logged in to submit a withdrawal."
msgstr "Debe iniciar sesión para enviar un desistimiento."

msgid "Invalid order."
msgstr "Pedido no válido."

msgid "Security check failed. Please go back and try again."
msgstr "La comprobación de seguridad ha fallado. Vuelva atrás e inténtelo de nuevo."

msgid "You are not authorized to access this order."
msgstr "No tiene permiso para acceder a este pedido."

msgid "You must check the confirmation box to submit a withdrawal."
msgstr "Debe marcar la casilla de confirmación para enviar el desistimiento."

msgid "This order is no longer eligible for withdrawal."
msgstr "Este pedido ya no admite desistimiento."

msgid "Customer submitted a withdrawal from the purchase contract."
msgstr "El cliente ha presentado un desistimiento del contrato de compra."

#. translators: %s: customer-provided reason
msgid "Reason: %s"
msgstr "Motivo: %s"

#. translators: %s: bank account for refund
msgid "Refund account: %s"
msgstr "Cuenta para el reembolso: %s"

msgid "Customer submitted withdrawal from purchase contract."
msgstr "Desistimiento del contrato de compra presentado por el cliente."

msgid "Withdrawal confirmation (customer)"
msgstr "Confirmación de desistimiento (cliente)"

msgid "Sent to the customer after they submit a withdrawal from a purchase contract."
msgstr "Se envía al cliente después de presentar un desistimiento de un contrato de compra."

msgid "[{site_title}] Withdrawal confirmation — order #{order_number}"
msgstr "[{site_title}] Confirmación de desistimiento — pedido #{order_number}"

msgid "Withdrawal confirmation"
msgstr "Confirmación de desistimiento"

msgid "If you have any questions about your withdrawal, please reply to this email."
msgstr "Si tiene alguna pregunta sobre su desistimiento, responda a este correo electrónico."

msgid "Withdrawal notification (admin)"
msgstr "Notificación de desistimiento (admin)"

msgid "Sent to the store administrator when a customer submits a withdrawal."
msgstr "Se envía al administrador de la tienda cuando un cliente presenta un desistimiento."

msgid "[{site_title}] New withdrawal request — order #{order_number}"
msgstr "[{site_title}] Nueva solicitud de desistimiento — pedido #{order_number}"

msgid "New withdrawal request"
msgstr "Nueva solicitud de desistimiento"

msgid "Enable/Disable"
msgstr "Activar/Desactivar"

msgid "Enable this email notification"
msgstr "Activar esta notificación por correo electrónico"

msgid "Recipient(s)"
msgstr "Destinatario(s)"

#. translators: %s: admin email
msgid "Enter recipients (comma separated). Defaults to %s."
msgstr "Introduzca los destinatarios (separados por comas). Por defecto: %s."

msgid "Subject"
msgstr "Asunto"

msgid "Placeholders: %s"
msgstr "Marcadores: %s"

msgid "Email heading"
msgstr "Encabezado del correo"

msgid "Email type"
msgstr "Tipo de correo"

msgid "Choose which format of email to send."
msgstr "Elija el formato del correo que se enviará."

msgid "Purchase Contract Withdrawal Button for WooCommerce"
msgstr "Botón de desistimiento del contrato de compra"

msgid "Withdrawal Button"
msgstr "Botón de desistimiento"

#. translators: %s: WooCommerce email settings URL
msgid "Customer and admin email templates can be customized in %s."
msgstr "Las plantillas de correo de cliente y administrador se pueden personalizar en %s."

msgid "WooCommerce → Settings → Emails"
msgstr "WooCommerce → Ajustes → Correos electrónicos"

msgid "Cooling-off period (days)"
msgstr "Plazo de desistimiento (días)"

msgid "How long after the reference date (order completion) the withdrawal button stays visible. EU standard is 14 days."
msgstr "Cuánto tiempo después de la fecha de referencia (finalización del pedido) permanece visible el botón de desistimiento. El estándar de la UE es de 14 días."

msgid "Eligible order statuses"
msgstr "Estados de pedido elegibles"

msgid "The button is shown only for orders in one of these statuses."
msgstr "El botón solo se muestra para los pedidos que estén en alguno de estos estados."

msgid "Admin email recipient"
msgstr "Destinatario del correo del administrador"

#. translators: %s: admin email
msgid "Leave empty to use the site admin email (%s)."
msgstr "Déjelo vacío para usar el correo del administrador del sitio (%s)."

msgid "Status after submission"
msgstr "Estado tras el envío"

msgid "Order status applied automatically after the customer submits a withdrawal."
msgstr "Estado del pedido aplicado automáticamente después de que el cliente presente un desistimiento."

msgid "Withdrawal from purchase contract"
msgstr "Desistimiento del contrato de compra"

#. translators: 1: order number, 2: deadline date
msgid "Complete the form below to withdraw from purchase contract no. %1$s. The cooling-off period ends on %2$s."
msgstr "Complete el siguiente formulario para desistir del contrato de compra n.º %1$s. El plazo de desistimiento finaliza el %2$s."

msgid "Order number"
msgstr "Número de pedido"

msgid "Order date"
msgstr "Fecha del pedido"

msgid "Customer"
msgstr "Cliente"

msgid "Address"
msgstr "Dirección"

msgid "Email"
msgstr "Correo electrónico"

msgid "Total"
msgstr "Total"

msgid "Bank account for refund"
msgstr "Cuenta bancaria para el reembolso"

msgid "(optional — leave empty to refund to the original payment method)"
msgstr "(opcional — déjelo vacío para reembolsar al método de pago original)"

msgid "Reason for withdrawal"
msgstr "Motivo del desistimiento"

msgid "(optional)"
msgstr "(opcional)"

msgid "I confirm that I am withdrawing from the purchase contract"
msgstr "Confirmo que desisto del contrato de compra"

msgid "and I understand that I must return the purchased goods within 14 days of submitting this withdrawal. The refund will be issued after the returned goods are received."
msgstr "y entiendo que debo devolver los bienes adquiridos en un plazo de 14 días desde el envío de este desistimiento. El reembolso se efectuará tras la recepción de los bienes devueltos."

msgid "Confirm withdrawal"
msgstr "Confirmar desistimiento"

msgid "Cancel"
msgstr "Cancelar"

msgid "Hello,"
msgstr "Hola:"

#. translators: 1: order number, 2: order date
msgid "We have received your withdrawal from the purchase contract for order no. %1$s placed on %2$s."
msgstr "Hemos recibido su desistimiento del contrato de compra correspondiente al pedido n.º %1$s realizado el %2$s."

msgid "Next steps"
msgstr "Próximos pasos"

msgid "Next steps:"
msgstr "Próximos pasos:"

msgid "Please return the goods to our address within 14 days of submitting this withdrawal."
msgstr "Devuelva los bienes a nuestra dirección en un plazo de 14 días desde el envío de este desistimiento."

msgid "We recommend shipping with tracking and insurance."
msgstr "Recomendamos un envío con seguimiento y asegurado."

#. translators: %s: total amount
msgid "Once we receive the goods we will refund the paid amount (%s) within 14 days."
msgstr "Una vez que recibamos los bienes, le reembolsaremos el importe pagado (%s) en un plazo de 14 días."

msgid "A customer has submitted a withdrawal from a purchase contract."
msgstr "Un cliente ha presentado un desistimiento de un contrato de compra."

msgid "Order"
msgstr "Pedido"

msgid "Phone"
msgstr "Teléfono"

msgid "Completion date"
msgstr "Fecha de finalización"

msgid "Refund account"
msgstr "Cuenta para el reembolso"

msgid "Original payment method"
msgstr "Método de pago original"

msgid "Reason"
msgstr "Motivo"

msgid "(not provided)"
msgstr "(no indicado)"

msgid "View order:"
msgstr "Ver pedido:"

# === 1.2.0 strings ===

msgid "A withdrawal has already been submitted for this order."
msgstr "Ya se ha presentado un desistimiento para este pedido."

msgid "an administrator"
msgstr "un administrador"

msgid "Customer (guest) submitted a withdrawal from the purchase contract."
msgstr "El cliente (invitado) ha presentado un desistimiento del contrato de compra."

#. translators: %s: admin display name
msgid "Withdrawal marked as resolved by %s."
msgstr "Desistimiento marcado como resuelto por %s."

#. translators: %s: admin display name
msgid "Withdrawal submitted on behalf of the customer by %s."
msgstr "Desistimiento presentado en nombre del cliente por %s."

msgid "The withdrawal form is not currently available. Please contact the store."
msgstr "El formulario de desistimiento no está disponible en este momento. Póngase en contacto con la tienda."

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email."
msgstr "Su desistimiento se ha enviado. Hemos enviado una confirmación a su correo electrónico."

msgid "Your session has expired. Please start the lookup again."
msgstr "Su sesión ha caducado. Inicie de nuevo la búsqueda."

msgid "Order not found."
msgstr "Pedido no encontrado."

msgid "Order number or email is missing or invalid."
msgstr "Falta el número de pedido o el correo electrónico, o no son válidos."

msgid "We could not find an order with the provided details."
msgstr "No hemos podido encontrar ningún pedido con los datos proporcionados."

msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "Demasiados intentos. Espere unos minutos e inténtelo de nuevo."

msgid "Security check failed. Please try again."
msgstr "La comprobación de seguridad ha fallado. Inténtelo de nuevo."

msgid "Enter your order number and the email address used when placing the order to continue."
msgstr "Para continuar, introduzca su número de pedido y la dirección de correo electrónico utilizada al realizar el pedido."

msgid "Billing email"
msgstr "Correo electrónico de facturación"

msgid "Continue"
msgstr "Continuar"

msgid "Withdrawal cooling-off"
msgstr "Plazo de desistimiento"

msgid "Date of delivery"
msgstr "Fecha de entrega"

msgid "Date the customer received the goods. Used as the reference date for the cooling-off period (leave empty to use the order completion date)."
msgstr "Fecha en la que el cliente recibió los bienes. Se utiliza como fecha de referencia para el plazo de desistimiento (déjelo vacío para usar la fecha de finalización del pedido)."

msgid "Cooling-off ends:"
msgstr "El plazo finaliza:"

#. translators: %d: number of days remaining
msgid "%d day remaining"
msgid_plural "%d days remaining"
msgstr[0] "queda %d día"
msgstr[1] "quedan %d días"

msgid "expired"
msgstr "vencido"

msgid "Withdrawal submitted:"
msgstr "Desistimiento enviado:"

msgid "Resolved:"
msgstr "Resuelto:"

msgid "Use the Order actions box to mark this withdrawal as resolved."
msgstr "Utilice el cuadro Acciones del pedido para marcar este desistimiento como resuelto."

msgid "guest form"
msgstr "formulario para invitados"

msgid "admin"
msgstr "admin"

msgid "customer account"
msgstr "cuenta de cliente"

msgid "Mark withdrawal as resolved"
msgstr "Marcar desistimiento como resuelto"

msgid "Submit withdrawal on behalf of customer"
msgstr "Enviar desistimiento en nombre del cliente"

msgid "Withdrawals"
msgstr "Desistimientos"

msgid "Export CSV"
msgstr "Exportar CSV"

msgid "Search"
msgstr "Buscar"

msgid "All"
msgstr "Todos"

msgid "Pending"
msgstr "Pendientes"

msgid "Resolved"
msgstr "Resueltos"

msgid "From"
msgstr "Desde"

msgid "To"
msgstr "Hasta"

msgid "Filter"
msgstr "Filtrar"

msgid "Submitted"
msgstr "Enviado"

msgid "Source"
msgstr "Origen"

msgid "Status"
msgstr "Estado"

msgid "Mark as resolved"
msgstr "Marcar como resuelto"

msgid "Resolve"
msgstr "Resolver"

msgid "guest"
msgstr "invitado"

msgid "customer"
msgstr "cliente"

#. translators: %d: number of withdrawals resolved
msgid "%d withdrawal marked as resolved."
msgid_plural "%d withdrawals marked as resolved."
msgstr[0] "%d desistimiento marcado como resuelto."
msgstr[1] "%d desistimientos marcados como resueltos."

msgid "You do not have permission to do this."
msgstr "No tiene permiso para realizar esta acción."

msgid "This order does not have a pending withdrawal."
msgstr "Este pedido no tiene ningún desistimiento pendiente."

msgid "This withdrawal has already been resolved."
msgstr "Este desistimiento ya se ha resuelto."

msgid "Guest withdrawal form"
msgstr "Formulario de desistimiento para invitados"

msgid "Enable shortcode for non-logged-in customers"
msgstr "Habilitar shortcode para clientes no conectados"

#. translators: %s: shortcode wrapped in <code>
msgid "Place %s on any page (e.g. a public landing page). The form will ask for an order number and the billing email, then show the withdrawal form."
msgstr "Coloque %s en cualquier página (por ejemplo, una landing pública). El formulario pedirá el número de pedido y el correo de facturación, y a continuación mostrará el formulario de desistimiento."
