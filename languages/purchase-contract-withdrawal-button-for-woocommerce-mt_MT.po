msgid ""
msgstr ""
"Project-Id-Version: Purchase Contract Withdrawal Button for WooCommerce 1.3.0\n"
"Report-Msgid-Bugs-To: \n"
"POT-Creation-Date: 2026-05-25 10:00+0000\n"
"PO-Revision-Date: 2026-05-29 12:00+0000\n"
"Last-Translator: Jakub Kašpárek\n"
"Language-Team: Maltese\n"
"Language: mt_MT\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=4; plural=(n==1 ? 0 : n==0 || (n%100>1 && n%100<11) ? 1 : (n%100>10 && n%100<20) ? 2 : 3);\n"
"X-Domain: purchase-contract-withdrawal-button-for-woocommerce\n"

msgid "Purchase Contract Withdrawal Button for WooCommerce requires WooCommerce to be installed and active."
msgstr "Il-plugin Purchase Contract Withdrawal Button for WooCommerce jeħtieġ li WooCommerce ikun installat u attiv."

msgid "Settings"
msgstr "Settings"

msgid "Withdraw from purchase contract"
msgstr "Irtira mill-kuntratt tax-xiri"

msgid "This order is no longer eligible for withdrawal (the cooling-off period has expired, or a withdrawal has already been submitted)."
msgstr "Din l-ordni m'għadhiex eliġibbli għall-irtirar (il-perjodu ta' ksuħ skada jew irtirar diġà ġie sottomess)."

msgid "Back to order"
msgstr "Lura għall-ordni"

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email. We will be in touch with return instructions."
msgstr "L-irtirar tiegħek ġie sottomess b'suċċess. Konferma ntbagħtet bl-email tiegħek. Aħna se nikkuntattjawk b'istruzzjonijiet għar-ritorn."

msgid "Withdrawal has been submitted"
msgstr "L-irtirar ġie sottomess"

#. translators: %s: submission date
msgid "on %s."
msgstr "fi %s."

#. translators: %s: admin email address
msgid "If you have any questions, contact us at %s."
msgstr "Jekk għandek mistoqsijiet, ikkuntattjana fi %s."

msgid "You must be logged in to submit a withdrawal."
msgstr "Trid tkun illoggjat biex tissottometti rtirar."

msgid "Invalid order."
msgstr "Ordni invalida."

msgid "Security check failed. Please go back and try again."
msgstr "Il-verifika tas-sigurtà fallat. Jekk jogħġbok mur lura u erġa' pprova."

msgid "You are not authorized to access this order."
msgstr "M'għandekx awtorizzazzjoni biex taċċessa din l-ordni."

msgid "You must check the confirmation box to submit a withdrawal."
msgstr "Trid tikkonferma l-kaxxa tal-konferma biex tissottometti rtirar."

msgid "This order is no longer eligible for withdrawal."
msgstr "Din l-ordni m'għadhiex eliġibbli għall-irtirar."

msgid "Customer submitted a withdrawal from the purchase contract."
msgstr "Il-klijent issottometta rtirar mill-kuntratt tax-xiri."

#. translators: %s: customer-provided reason
msgid "Reason: %s"
msgstr "Raġuni: %s"

#. translators: %s: bank account for refund
msgid "Refund account: %s"
msgstr "Kont għar-rifużjoni: %s"

msgid "Customer submitted withdrawal from purchase contract."
msgstr "Il-klijent issottometta rtirar mill-kuntratt tax-xiri."

msgid "Withdrawal confirmation (customer)"
msgstr "Konferma tal-irtirar (klijent)"

msgid "Sent to the customer after they submit a withdrawal from a purchase contract."
msgstr "Mibgħut lill-klijent wara li jissottometti rtirar minn kuntratt tax-xiri."

msgid "[{site_title}] Withdrawal confirmation — order #{order_number}"
msgstr "[{site_title}] Konferma tal-irtirar — ordni #{order_number}"

msgid "Withdrawal confirmation"
msgstr "Konferma tal-irtirar"

msgid "If you have any questions about your withdrawal, please reply to this email."
msgstr "Jekk għandek mistoqsijiet dwar l-irtirar tiegħek, jekk jogħġbok wieġeb għal din l-email."

msgid "Withdrawal notification (admin)"
msgstr "Notifika ta' rtirar (amministratur)"

msgid "Sent to the store administrator when a customer submits a withdrawal."
msgstr "Mibgħut lill-amministratur tal-ħanut meta klijent jissottometti rtirar."

msgid "[{site_title}] New withdrawal request — order #{order_number}"
msgstr "[{site_title}] Talba ġdida ta' rtirar — ordni #{order_number}"

msgid "New withdrawal request"
msgstr "Talba ġdida ta' rtirar"

msgid "Enable/Disable"
msgstr "Attiva/Diżattiva"

msgid "Enable this email notification"
msgstr "Attiva din in-notifika bl-email"

msgid "Recipient(s)"
msgstr "Riċevitur(i)"

#. translators: %s: admin email
msgid "Enter recipients (comma separated). Defaults to %s."
msgstr "Daħħal ir-riċevituri (separati bil-virgola). Default: %s."

msgid "Subject"
msgstr "Suġġett"

msgid "Placeholders: %s"
msgstr "Placeholders: %s"

msgid "Email heading"
msgstr "Titlu tal-email"

msgid "Email type"
msgstr "Tip ta' email"

msgid "Choose which format of email to send."
msgstr "Agħżel liema format ta' email għandu jintbagħat."

msgid "Purchase Contract Withdrawal Button for WooCommerce"
msgstr "Buttuna tal-Irtirar mill-Kuntratt tax-Xiri"

msgid "Withdrawal Button"
msgstr "Buttuna tal-Irtirar"

#. translators: %s: WooCommerce email settings URL
msgid "Customer and admin email templates can be customized in %s."
msgstr "It-templates tal-email tal-klijenti u tal-amministratur jistgħu jiġu personalizzati fi %s."

msgid "WooCommerce → Settings → Emails"
msgstr "WooCommerce → Settings → Emails"

msgid "Cooling-off period (days)"
msgstr "Perjodu ta' ksuħ (jiem)"

msgid "How long after the reference date (order completion) the withdrawal button stays visible. EU standard is 14 days."
msgstr "Kemm żmien wara d-data ta' referenza (tlestija tal-ordni) il-buttuna tal-irtirar tibqa' viżibbli. L-istandard tal-UE huwa 14-il jum."

msgid "Eligible order statuses"
msgstr "Statusi tal-ordni eliġibbli"

msgid "The button is shown only for orders in one of these statuses."
msgstr "Il-buttuna tidher biss għal ordnijiet f'wieħed minn dawn l-istatusi."

msgid "Admin email recipient"
msgstr "Riċevitur tal-email tal-amministratur"

#. translators: %s: admin email
msgid "Leave empty to use the site admin email (%s)."
msgstr "Ħalli vojta biex tuża l-email tal-amministratur tas-sit (%s)."

msgid "Status after submission"
msgstr "Status wara s-sottomissjoni"

msgid "Order status applied automatically after the customer submits a withdrawal."
msgstr "L-istatus tal-ordni applikat awtomatikament wara li l-klijent jissottometti rtirar."

msgid "Withdrawal from purchase contract"
msgstr "Irtirar mill-kuntratt tax-xiri"

#. translators: 1: order number, 2: deadline date
msgid "Complete the form below to withdraw from purchase contract no. %1$s. The cooling-off period ends on %2$s."
msgstr "Imla l-formola hawn taħt biex tirtira mill-kuntratt tax-xiri nru. %1$s. Il-perjodu ta' ksuħ jintemm fi %2$s."

msgid "Order number"
msgstr "Numru tal-ordni"

msgid "Order date"
msgstr "Data tal-ordni"

msgid "Customer"
msgstr "Klijent"

msgid "Address"
msgstr "Indirizz"

msgid "Email"
msgstr "Email"

msgid "Total"
msgstr "Total"

msgid "Bank account for refund"
msgstr "Kont bankarju għar-rifużjoni"

msgid "(optional — leave empty to refund to the original payment method)"
msgstr "(mhux obbligatorju — ħalli vojt biex tirrifondi għall-metodu oriġinali ta' ħlas)"

msgid "Reason for withdrawal"
msgstr "Raġuni għall-irtirar"

msgid "(optional)"
msgstr "(mhux obbligatorju)"

msgid "I confirm that I am withdrawing from the purchase contract"
msgstr "Nikkonferma li qed nirtira mill-kuntratt tax-xiri"

msgid "and I understand that I must return the purchased goods within 14 days of submitting this withdrawal. The refund will be issued after the returned goods are received."
msgstr "u nifhem li jrid nirritorna l-merkanzija mixtrija fi żmien 14-il jum mis-sottomissjoni ta' dan l-irtirar. Ir-rifużjoni se tinħareġ wara li jirċievu l-merkanzija mibgħuta lura."

msgid "Confirm withdrawal"
msgstr "Ikkonferma l-irtirar"

msgid "Cancel"
msgstr "Ikkanċella"

msgid "Hello,"
msgstr "Bonġu,"

#. translators: 1: order number, 2: order date
msgid "We have received your withdrawal from the purchase contract for order no. %1$s placed on %2$s."
msgstr "Irċevejna l-irtirar tiegħek mill-kuntratt tax-xiri għall-ordni nru. %1$s magħmula fi %2$s."

msgid "Next steps"
msgstr "Passi li jmiss"

msgid "Next steps:"
msgstr "Passi li jmiss:"

msgid "Please return the goods to our address within 14 days of submitting this withdrawal."
msgstr "Jekk jogħġbok irritorna l-merkanzija lill-indirizz tagħna fi żmien 14-il jum mis-sottomissjoni ta' dan l-irtirar."

msgid "We recommend shipping with tracking and insurance."
msgstr "Nirrakkomandaw li tibgħathom b'tracking u assigurazzjoni."

#. translators: %s: total amount
msgid "Once we receive the goods we will refund the paid amount (%s) within 14 days."
msgstr "Ladarba nirċievu l-merkanzija aħna nirrifondu l-ammont imħallas (%s) fi żmien 14-il jum."

msgid "A customer has submitted a withdrawal from a purchase contract."
msgstr "Klijent issottometta rtirar minn kuntratt tax-xiri."

msgid "Order"
msgstr "Ordni"

msgid "Phone"
msgstr "Telefown"

msgid "Completion date"
msgstr "Data ta' tlestija"

msgid "Refund account"
msgstr "Kont għar-rifużjoni"

msgid "Original payment method"
msgstr "Metodu oriġinali ta' ħlas"

msgid "Reason"
msgstr "Raġuni"

msgid "(not provided)"
msgstr "(mhux ipprovdut)"

msgid "View order:"
msgstr "Ara l-ordni:"

# === 1.2.0 strings ===

msgid "A withdrawal has already been submitted for this order."
msgstr "Irtirar diġà ġie sottomess għal din l-ordni."

msgid "an administrator"
msgstr "amministratur"

msgid "Customer (guest) submitted a withdrawal from the purchase contract."
msgstr "Klijent (mistieden) issottometta rtirar mill-kuntratt tax-xiri."

#. translators: %s: admin display name
msgid "Withdrawal marked as resolved by %s."
msgstr "L-irtirar immarkat bħala riżolt minn %s."

#. translators: %s: admin display name
msgid "Withdrawal submitted on behalf of the customer by %s."
msgstr "Irtirar sottomess f'isem il-klijent minn %s."

msgid "The withdrawal form is not currently available. Please contact the store."
msgstr "Il-formola tal-irtirar bħalissa mhix disponibbli. Jekk jogħġbok ikkuntattja l-ħanut."

msgid "Your withdrawal has been submitted. A confirmation has been sent to your email."
msgstr "L-irtirar tiegħek ġie sottomess. Konferma ntbagħtet bl-email tiegħek."

msgid "Your session has expired. Please start the lookup again."
msgstr "Is-sessjoni tiegħek skadiet. Jekk jogħġbok erġa' ibda t-tfittxija."

msgid "Order not found."
msgstr "L-ordni ma nstabitx."

msgid "Order number or email is missing or invalid."
msgstr "In-numru tal-ordni jew l-email huma nieqsa jew invalidi."

msgid "We could not find an order with the provided details."
msgstr "Ma stajniex insibu ordni bid-dettalji pprovduti."

msgid "Too many attempts. Please wait a few minutes and try again."
msgstr "Wisq tentattivi. Jekk jogħġbok stenna ftit minuti u erġa' pprova."

msgid "Security check failed. Please try again."
msgstr "Il-verifika tas-sigurtà fallat. Jekk jogħġbok erġa' pprova."

msgid "Enter your order number and the email address used when placing the order to continue."
msgstr "Daħħal in-numru tal-ordni tiegħek u l-indirizz email użat meta għamilt l-ordni biex tkompli."

msgid "Billing email"
msgstr "Email tal-fatturazzjoni"

msgid "Continue"
msgstr "Kompli"

msgid "Withdrawal cooling-off"
msgstr "Perjodu ta' ksuħ"

msgid "Date of delivery"
msgstr "Data tal-konsenja"

msgid "Date the customer received the goods. Used as the reference date for the cooling-off period (leave empty to use the order completion date)."
msgstr "Id-data meta l-klijent irċieva l-merkanzija. Tintuża bħala d-data ta' referenza għall-perjodu ta' ksuħ (ħalli vojta biex tuża d-data ta' tlestija tal-ordni)."

msgid "Cooling-off ends:"
msgstr "Il-perjodu ta' ksuħ jintemm:"

#. translators: %d: number of days remaining
msgid "%d day remaining"
msgid_plural "%d days remaining"
msgstr[0] "fadal %d jum"
msgstr[1] "fadal %d ijiem"
msgstr[2] "fadal %d-il jum"
msgstr[3] "fadal %d jum"

msgid "expired"
msgstr "skadut"

msgid "Withdrawal submitted:"
msgstr "Irtirar sottomess:"

msgid "Resolved:"
msgstr "Riżolt:"

msgid "Use the Order actions box to mark this withdrawal as resolved."
msgstr "Uża l-kaxxa tal-Azzjonijiet tal-Ordni biex timmarka dan l-irtirar bħala riżolt."

msgid "guest form"
msgstr "formola tal-mistieden"

msgid "admin"
msgstr "amministratur"

msgid "customer account"
msgstr "kont tal-klijent"

msgid "Mark withdrawal as resolved"
msgstr "Immarka l-irtirar bħala riżolt"

msgid "Submit withdrawal on behalf of customer"
msgstr "Issottometti rtirar f'isem il-klijent"

msgid "Withdrawals"
msgstr "Irtirar"

msgid "Export CSV"
msgstr "Esporta CSV"

msgid "Search"
msgstr "Fittex"

msgid "All"
msgstr "Kollha"

msgid "Pending"
msgstr "Pendenti"

msgid "Resolved"
msgstr "Riżolt"

msgid "From"
msgstr "Minn"

msgid "To"
msgstr "Sa"

msgid "Filter"
msgstr "Iffiltra"

msgid "Submitted"
msgstr "Sottomess"

msgid "Source"
msgstr "Sors"

msgid "Status"
msgstr "Status"

msgid "Mark as resolved"
msgstr "Immarka bħala riżolt"

msgid "Resolve"
msgstr "Irriżolvi"

msgid "guest"
msgstr "mistieden"

msgid "customer"
msgstr "klijent"

#. translators: %d: number of withdrawals resolved
msgid "%d withdrawal marked as resolved."
msgid_plural "%d withdrawals marked as resolved."
msgstr[0] "%d irtirar immarkat bħala riżolt."
msgstr[1] "%d irtirari immarkati bħala riżolti."
msgstr[2] "%d-il irtirar immarkati bħala riżolti."
msgstr[3] "%d irtirari immarkati bħala riżolti."

msgid "You do not have permission to do this."
msgstr "M'għandekx permess biex tagħmel dan."

msgid "This order does not have a pending withdrawal."
msgstr "Din l-ordni m'għandhiex irtirar pendenti."

msgid "This withdrawal has already been resolved."
msgstr "Dan l-irtirar diġà ġie riżolt."

msgid "Guest withdrawal form"
msgstr "Formola tal-irtirar għal mistednin"

msgid "Enable shortcode for non-logged-in customers"
msgstr "Attiva shortcode għal klijenti mhux illoggjati"

#. translators: %s: shortcode wrapped in <code>
msgid "Place %s on any page (e.g. a public landing page). The form will ask for an order number and the billing email, then show the withdrawal form."
msgstr "Poġġi %s fuq kwalunkwe paġna (eż. paġna pubblika tal-bidu). Il-formola se titlob in-numru tal-ordni u l-email tal-fatturazzjoni, imbagħad turi l-formola tal-irtirar."
